<div class="game-tile-surface cc-tile">
    <div class="cc-felt-glow" aria-hidden="true"></div>

    <div class="cc-fan" aria-hidden="true">
        <div class="cc-card cc-card-left">
            <div class="cc-card-trim"></div>
        </div>
        <div class="cc-card cc-card-mid">
            <div class="cc-card-trim"></div>
        </div>
        <div class="cc-card cc-card-right">
            <div class="cc-card-trim"></div>
        </div>
    </div>

    <div class="cc-chips" aria-hidden="true">
        <span class="cc-chip cc-chip-3"></span>
        <span class="cc-chip cc-chip-2"></span>
        <span class="cc-chip cc-chip-1"></span>
    </div>

    <div class="cc-tile-name">Card Counter</div>
    <div class="cc-tile-tag">Bluff, count cards, bust the table.</div>
</div>
