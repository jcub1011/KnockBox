@page "/room/codeword/{ObfuscatedRoomCode}"

@inherits DisposableComponent
@using KnockBox.Codeword.Services.State.Games
@using KnockBox.Codeword.Services.Logic.Games.FSM
@using KnockBox.Core.Services.State.Games.Shared
@using KnockBox.Core.Components.Shared

<PageTitle>Codeword</PageTitle>

<HeadContent>
    <link href="_content/KnockBox.Codeword/KnockBox.Codeword.styles.css" rel="stylesheet" />
</HeadContent>

@if (GameState == null)
{
    <div class="ctc-loading">
        <span class="ctc-loading-icon">🔍</span>
        <span>Loading room...</span>
    </div>
}
else
{
    var isInformant = false;
    if (UserService.CurrentUser != null && GameState.GamePlayers.TryGetValue(UserService.CurrentUser.Id, out var p))
    {
        isInformant = p.Role == KnockBox.Codeword.Services.State.Games.Role.Informant;
    }
    
    <div class="ctc-crt-bezel">
    <div class="ctc-crt-screen @(isInformant ? "ctc-state-informant" : "")">
        <div class="ctc-page">

            @if (GameState.Config.EnableTimers && GameState.Context?.Fsm?.CurrentState is ITimedGameState<CodewordGameContext, CodewordCommand> timedState)
            {
                var remaining = timedState.GetRemainingTime(GameState.Context!, DateTimeOffset.UtcNow);
                if (remaining.IsSuccess && remaining.Value.TotalSeconds >= 0)
                {
                    var endTime = DateTimeOffset.UtcNow.Add(remaining.Value);
                    var duration = TimeSpan.FromMilliseconds(GetPhaseTotalMs());

                    <CountdownClock EndTimeUtc="endTime" Duration="duration" Context="countdown">
                        @{
                            var barWidth = 20;
                            var filled = (int)Math.Ceiling(countdown.Fraction * barWidth);
                            var empty = barWidth - filled;
                            var bar = new string('\u2588', filled) + new string('\u2591', empty);
                            var seconds = (int)Math.Ceiling(countdown.RemainingSeconds);
                        }
                        <div class="ctc-timer-container">
                            <div class="ctc-timer-bar @(seconds < 5 ? "ctc-timer-urgent" : "")">
                                <span class="ctc-timer-text">[@bar] @(seconds)s</span>
                            </div>
                        </div>
                    </CountdownClock>
                }
            }

            @* ── Error toast ── *@
            @if (_errorMessage is not null)
            {
                <div @key="_errorKey" class="ctc-error-toast" @onanimationend="DismissError">
                    <span class="ctc-error-icon">⚠️</span>
                    <span>@_errorMessage</span>
                </div>
            }

            @if (GameState.IsJoinable)
            {
                <LobbyPhase GameState="GameState" />
            }
            else
            {
                @switch (GameState.Phase)
                {
                    case CodewordGamePhase.Setup:
                        <SetupPhase GameState="GameState" />
                        break;
                    case CodewordGamePhase.CluePhase:
                        <CluePhase GameState="GameState" OnError="ShowError" />
                        break;
                    case CodewordGamePhase.Discussion:
                        <DiscussionPhase GameState="GameState" OnError="ShowError" />
                        break;
                    case CodewordGamePhase.Voting:
                        <VotePhase GameState="GameState" OnError="ShowError" />
                        break;
                    case CodewordGamePhase.Reveal:
                        <RevealPhase GameState="GameState" OnError="ShowError" />
                        break;
                    case CodewordGamePhase.GameOver:
                        <GameOverPhase GameState="GameState" />
                        break;
                }
            }

        </div>
    </div>
    </div>
}

