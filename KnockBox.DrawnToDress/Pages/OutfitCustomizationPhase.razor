@using KnockBox.Core.Components.Shared
@using KnockBox.DrawnToDress.Services.Logic.Games
@using KnockBox.DrawnToDress.Services.State.Games
@using KnockBox.DrawnToDress.Services.State.Games.Data
@using KnockBox.Core.Services.State.Users

@{
    bool isHost = UserService.CurrentUser?.Id == GameState.Host.Id;

    string? myId = UserService.CurrentUser?.Id;
    var myPlayer = myId is not null && GameState.GamePlayers.TryGetValue(myId, out var pOut) ? pOut : null;
    bool hasSubmitted = myPlayer?.IsReady ?? false;

    int submittedCount = GameState.GamePlayers.Values.Count(p => p.IsReady);
    int totalPlayers = GameState.GamePlayers.Count;

    string phaseName = OutfitRound == 1 ? "Customize Outfit" : $"Customize Outfit {OutfitRound}";
    string nameLabel = OutfitRound == 1 ? "Outfit Name" : $"Outfit {OutfitRound} Name";
    string finalizeLabel = OutfitRound == 1 ? "Finalize Outfit" : $"Finalize Outfit {OutfitRound}";
    string finalizedMessage = OutfitRound == 1 ? "Outfit finalized! Waiting for the others\u2026" : $"Outfit {OutfitRound} finalized! Waiting for the others\u2026";

    var myOutfit = myPlayer?.GetOutfit(OutfitRound);

    int canvasWidth = CompositeCanvasLayout.ComputeCompositeWidth(GameState.Config.ClothingTypes);
    int totalOutfitHeight = CompositeCanvasLayout.ComputeCompositeHeight(GameState.Config.ClothingTypes);
    double mannequinSize = CompositeCanvasLayout.MannequinDisplaySize(GameState.Config.ClothingTypes);

    // Build a composite background SVG from the player's selected outfit items, applying
    // any position overrides set via the drag/manual-input layer.
    string? outfitBackground = null;
    string? mannequinSvg = null;
    if (!isHost && !hasSubmitted && myOutfit is not null)
    {
        var bgParts = new System.Text.StringBuilder();

        if (_mode == InteractionMode.Draw)
        {
            foreach (var ct in GameState.Config.ClothingTypes)
            {
                if (myOutfit.SelectedItemsByType.TryGetValue(ct.Id, out var itemId)
                    && GameState.ClothingPool.TryGetValue(itemId, out var bgItem)
                    && bgItem.SvgContent is not null)
                {
                    double itemX = 0;
                    double itemY = 0;
                    if (_itemPositions.TryGetValue(ct.Id, out var posOverride))
                    {
                        itemX = posOverride.X;
                        itemY = posOverride.Y;
                    }

                    bgParts.Append($"<g transform=\"translate({itemX},{itemY})\">");
                    bgParts.Append(bgItem.SvgContent);
                    bgParts.Append("</g>");
                }
            }
        }

        if (_showMannequin && GameState.Config.ShowMannequin)
        {
            mannequinSvg = MannequinSvgHelper.Build(canvasWidth, totalOutfitHeight, overrideDisplaySize: mannequinSize);
        }

        if (bgParts.Length > 0)
            outfitBackground = bgParts.ToString();
    }
}

<div class="dtd-customization">

    <!-- ── Header ────────────────────────────────────────────────────────── -->
    <header class="dtd-customization-header">
        <div class="dtd-customization-phase-badge">
            <span class="dtd-customization-phase-icon" aria-hidden="true">✏️</span>
            <h2 class="dtd-customization-phase-name">@phaseName</h2>
        </div>

        @* <div class="dtd-customization-progress-pill" aria-label="Player progress">
            @submittedCount / @totalPlayers finalized
        </div> *@

        <TimerDisplay GameState="GameState" />
    </header>

    <main class="dtd-customization-main">
        <!-- ── Host view ─────────────────────────────────────────────────────── -->
        @if (isHost)
        {
            <div class="dtd-customization-host-panel">
                <h3 class="dtd-customization-section-title">Outfit Runway</h3>
                <div class="dtd-customization-player-grid">
                    @foreach (var kv in GameState.GamePlayers)
                    {
                        var ps = kv.Value;
                        string statusIcon = ps.IsReady ? "✅" : "⏳";
                        var outfit = ps.GetOutfit(OutfitRound);
                        string? outfitName = outfit?.Customization.OutfitName;
                        if (string.IsNullOrWhiteSpace(outfitName)) outfitName = "Naming outfit…";
                        <div class="dtd-customization-player-card @(ps.IsReady ? "dtd-customization-player-ready" : "")">
                            <span class="dtd-customization-player-name">@ps.DisplayName</span>
                            <div class="dtd-customization-runway-preview">
                                @if (outfit != null)
                                {
                                    <svg viewBox="0 0 @canvasWidth @totalOutfitHeight" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg">
                                        @foreach (var ct in GameState.Config.ClothingTypes)
                                        {
                                            if (outfit.SelectedItemsByType.TryGetValue(ct.Id, out var itemId)
                                                && GameState.ClothingPool.TryGetValue(itemId, out var item))
                                            {
                                                if (KnockBox.Core.Services.Drawing.SvgContentSanitizer.Sanitize(item.SvgContent) is string safeSvg)
                                                {
                                                    var (itemX, itemY) = CompositeCanvasLayout.GetItemPosition(
                                                        ct.Id, ct.CanvasWidth, ct.CanvasHeight, canvasWidth, totalOutfitHeight,
                                                        outfit.Customization.ItemPositionOverrides);
                                                    <g transform="translate(@itemX,@itemY)">
                                                        @((MarkupString)safeSvg)
                                                    </g>
                                                }
                                            }
                                        }
                                        @if (outfit.Customization.SketchSvgContent is not null && KnockBox.Core.Services.Drawing.SvgContentSanitizer.Sanitize(outfit.Customization.SketchSvgContent) is string sketchSvg)
                                        {
                                            @((MarkupString)sketchSvg)
                                        }
                                    </svg>
                                }
                            </div>
                            <span class="dtd-customization-player-detail">
                                @if (ps.IsReady)
                                {
                                    <span>"@outfitName"</span>
                                }
                                else
                                {
                                    <span>@outfitName</span>
                                }
                            </span>
                            <span class="dtd-customization-player-status-badge">
                                @(ps.IsReady ? "Finalized" : "Customizing...")
                            </span>
                        </div>
                    }
                </div>
            </div>
        }
        else if (hasSubmitted)
        {
            <div class="dtd-customization-waiting-card">
                <div class="dtd-customization-waiting-header">
                    <span class="dtd-customization-waiting-icon">🌟</span>
                    <p class="dtd-customization-waiting-text">@finalizedMessage</p>
                </div>
                
                <div class="dtd-customization-submitted-preview">
                    <p class="dtd-customization-submitted-name">
                        "@myOutfit!.Customization.OutfitName"
                    </p>
                    @if (myOutfit.Customization.SketchSvgContent is not null)
                    {
                        <span class="dtd-customization-submitted-badge">Sketch Overlay Added ✏️</span>
                    }
                </div>
            </div>
        }
        else
        {
            <div class="dtd-customization-editor-layout">
                <section class="dtd-customization-controls-panel">
                    <div class="dtd-customization-field">
                        <label class="dtd-customization-label" for="outfit-name-input">
                            @nameLabel <span class="dtd-customization-required">*</span>
                        </label>
                        <input id="outfit-name-input"
                               class="dtd-customization-input"
                               type="text"
                               placeholder="Name your creation..."
                               maxlength="60"
                               value="@_outfitName"
                               @oninput="(e) => OnOutfitNameChangedAsync(e.Value?.ToString() ?? string.Empty)" />
                    </div>

                    <div class="dtd-customization-field">
                        <label class="dtd-customization-label">Edit Mode</label>
                        <div class="dtd-customization-mode-toggle">
                            <button class="dtd-btn-mode @(_mode == InteractionMode.Draw ? "dtd-btn-mode-active" : "")"
                                    aria-pressed="@(_mode == InteractionMode.Draw ? "true" : "false")"
                                    @onclick="() => SwitchModeAsync(InteractionMode.Draw)">
                                🖌️ Draw
                            </button>
                            <button class="dtd-btn-mode @(_mode == InteractionMode.MoveItems ? "dtd-btn-mode-active" : "")"
                                    aria-pressed="@(_mode == InteractionMode.MoveItems ? "true" : "false")"
                                    @onclick="() => SwitchModeAsync(InteractionMode.MoveItems)">
                                🖐️ Move
                            </button>
                        </div>
                    </div>

                    @if (_mode == InteractionMode.MoveItems)
                    {
                        <div class="dtd-customization-field">
                            <label class="dtd-customization-label">Select Item</label>
                            <div class="dtd-customization-item-selector">
                                @foreach (var ct in GameState.Config.ClothingTypes)
                                {
                                    var typeId = ct.Id;
                                    bool isSelected = _selectedTypeId == typeId;
                                    <button class="dtd-item-select-btn @(isSelected ? "dtd-item-select-btn-active" : "")"
                                            aria-pressed="@(isSelected ? "true" : "false")"
                                            @onclick="() => SelectItemAsync(typeId)">
                                        <span class="dtd-item-select-icon" aria-hidden="true">@GetClothingTypeIcon(ct.Id)</span>
                                        <span class="dtd-item-select-name">@ct.DisplayName</span>
                                    </button>
                                }
                            </div>
                        </div>
                    }

                    <div class="dtd-customization-spacer"></div>

                    <div class="dtd-customization-actions">
                        @if (_errorMessage is not null)
                        {
                            <p class="dtd-customization-error" role="alert">@_errorMessage</p>
                        }
                        <button class="dtd-btn dtd-btn-primary dtd-btn-lg"
                                @onclick="SubmitCustomizationAsync"
                                disabled="@_submitting">
                            @(_submitting ? "Finalizing..." : "Finalize")
                        </button>

                        @if (GameState.Config.ShowMannequin)
                        {
                            <div class="dtd-customization-field">
                                <label class="dtd-customization-checkbox-label">
                                    <input type="checkbox" @bind="_showMannequin" />
                                    Show Mannequin Reference
                                </label>
                            </div>
                        }
                    </div>
                </section>

                <section class="dtd-customization-canvas-panel">
                    <div class="dtd-customization-canvas-container @(_mode == InteractionMode.MoveItems ? "dtd-canvas-move-mode" : "")">
                        <SvgDrawingCanvas @ref="_sketchCanvas"
                                          Width="100%"
                                          Height="100%"
                                          ViewBoxWidth="@canvasWidth"
                                          ViewBoxHeight="@totalOutfitHeight"
                                          BackgroundColor="#ffffff"
                                          TrustedBackgroundSvgContent="@mannequinSvg"
                                          BackgroundSvgContent="@outfitBackground"
                                          ShowToolbar="@(_mode == InteractionMode.Draw)">
                            <OverlayContent>
                                @if (_mode == InteractionMode.MoveItems)
                                {
                                    <svg id="@_dragSvgId"
                                         class="dtd-customization-drag-layer"
                                         style="z-index: 3;"
                                         width="@canvasWidth" height="@totalOutfitHeight"
                                         viewBox="0 0 @canvasWidth @totalOutfitHeight"
                                         preserveAspectRatio="xMidYMid meet"
                                         xmlns="http://www.w3.org/2000/svg">
                                        @if (mannequinSvg is not null)
                                        {
                                            @((MarkupString)mannequinSvg)
                                        }
                                    </svg>
                                }
                            </OverlayContent>
                        </SvgDrawingCanvas>
                    </div>

                    @if (_mode == InteractionMode.MoveItems && false) // Keep hidden
                    {
                        <div class="dtd-customization-manual-pos">
                            <details class="dtd-card">
                                <summary>Manual Position Controls</summary>
                                <div class="dtd-manual-pos-grid">
                                    @foreach (var ct in GameState.Config.ClothingTypes)
                                    {
                                        var typeId = ct.Id;
                                        _itemPositions.TryGetValue(typeId, out var pos);
                                        <div class="dtd-manual-pos-row">
                                            <span class="dtd-manual-pos-label">@ct.DisplayName</span>
                                            <input type="number" class="dtd-customization-input-sm" value="@((int)(pos?.X ?? 0))" 
                                                   @onchange="(e) => OnManualPositionChanged(typeId, true, e)" title="X Position" />
                                            <input type="number" class="dtd-customization-input-sm" value="@((int)(pos?.Y ?? 0))" 
                                                   @onchange="(e) => OnManualPositionChanged(typeId, false, e)" title="Y Position" />
                                        </div>
                                    }
                                </div>
                            </details>
                        </div>
                    }
                </section>
            </div>
        }
    </main>
</div>


