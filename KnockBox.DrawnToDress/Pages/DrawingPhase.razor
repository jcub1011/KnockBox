@using KnockBox.Core.Components.Shared
@using KnockBox.DrawnToDress.Services.State.Games
@using KnockBox.DrawnToDress.Services.State.Games.Data
@using KnockBox.Core.Services.State.Users

@{
    bool isHost = UserService.CurrentUser?.Id == GameState.Host.Id;

    string? myId = UserService.CurrentUser?.Id;
    var myPlayer = myId is not null && GameState.GamePlayers.TryGetValue(myId, out var pOut) ? pOut : null;
    int mySubmitted = myPlayer is not null ? CountSubmittedForCurrentType(myPlayer) : 0;
    int myMax = CurrentTypeMaxItems;
    bool canSubmit = myMax == 0 || mySubmitted < myMax;
    bool isDone = myPlayer?.IsReady ?? false;
}

<div class="dtd-drawing">

    <div class="dtd-drawing-header">
        <div class="dtd-drawing-type-badge">
            <span class="dtd-drawing-type-icon">🎨</span>
            <span class="dtd-drawing-type-name">
                @CurrentTypeName
                @if (GameState.ThemeRevealedToPlayers && GameState.CurrentTheme is not null)
                {
                    <span class="dtd-drawing-theme-reveal"> — @GameState.CurrentTheme.DisplayName</span>
                }
            </span>
        </div>

        <div class="dtd-drawing-round-info">
            <span>Round @(GameState.CurrentDrawingClothingTypeIndex + 1) of @GameState.Config.ClothingTypes.Count</span>
            <span>|</span>
            <span>Drawing @mySubmitted@(myMax > 0 ? $" of {myMax}" : "")</span>
            @if (!canSubmit)
            {
                <span class="dtd-drawing-counter-full">✅</span>
            }
        </div>

        <div class="dtd-drawing-round-info-row">
            @if (!isHost)
            {
                <button class="dtd-btn dtd-btn-secondary dtd-btn-mannequin @(_showMannequin ? "dtd-btn-mannequin-active" : "")"
                        @onclick="ToggleMannequin"
                        aria-label="Toggle mannequin reference"
                        title="Toggle mannequin reference">
                    👤
                </button>
            }

            <TimerDisplay GameState="GameState" />
        </div>
    </div>

    @if (isHost)
    {
        <div class="dtd-drawing-host-panel">
            <h3 class="dtd-drawing-host-title">Players are drawing: @CurrentTypeName</h3>

            @{
                var drawings = GameState.ClothingPool.Values.Where(item => item.ClothingTypeId == CurrentTypeId).ToList();
                int totalPossible = GameState.GamePlayers.Count * (CurrentTypeMaxItems > 0 ? CurrentTypeMaxItems : 1); // Assuming 1 min if 0
                int totalSubmitted = drawings.Count;
            }

            @if (GameState.Config.ShowDrawingsOnHostScreen)
            {
                <div class="dtd-drawing-gallery">
                    @foreach (var drawing in drawings)
                    {
                        <div class="dtd-card dtd-drawing-thumbnail-card">
                            <div class="dtd-drawing-thumbnail">
                                <svg viewBox="0 0 @CurrentTypeCanvasWidth @CurrentTypeCanvasHeight"
                                     preserveAspectRatio="xMidYMid meet"
                                     xmlns="http://www.w3.org/2000/svg">
                                    @((MarkupString)(SafeSvgContent(drawing.SvgContent) ?? ""))
                                </svg>
                            </div>
                            <div class="dtd-drawing-creator">
                                @(GameState.GamePlayers.GetValueOrDefault(drawing.CreatorPlayerId)?.DisplayName ?? "Unknown")
                            </div>
                        </div>
                    }
                    @for (int i = 0; i < totalPossible - totalSubmitted; i++)
                    {
                        <div class="dtd-card dtd-drawing-thumbnail-placeholder">
                            <div class="dtd-drawing-placeholder-icon">?</div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="dtd-drawing-progress-mode">
                    <div class="dtd-drawing-progress-counter">
                        <span class="dtd-drawing-count">@totalSubmitted / @totalPossible</span>
                        <span class="dtd-drawing-count-label">drawings</span>
                    </div>
                    <div class="dtd-drawing-progress-subtitle">Artists at work...</div>
                </div>
            }

            <div class="dtd-drawing-progress-container">
                <div class="dtd-drawing-progress-bar" style="width: @(totalPossible > 0 ? (totalSubmitted * 100.0 / totalPossible) : 100)%"></div>
            </div>
            
            <p class="dtd-drawing-host-hint">
                The round advances automatically when the timer expires or all players are done.
            </p>
        </div>
    }
    else
    {
        <div class="dtd-drawing-player-panel">
            @if (!isDone)
            {
                <div class="dtd-drawing-canvas-container">
                    <div class="dtd-drawing-canvas-wrapper" role="img" aria-label="Drawing canvas for @CurrentTypeName">
                        <SvgDrawingCanvas @ref="_canvas"
                                          Width="100%"
                                          Height="100%"
                                          ViewBoxWidth="@CurrentTypeCanvasWidth"
                                          ViewBoxHeight="@CurrentTypeCanvasHeight"
                                          BackgroundColor="#ffffff"
                                          TrustedBackgroundSvgContent="@MannequinSvg" />
                    </div>
                </div>

                <div class="dtd-drawing-footer">
                    <div class="dtd-drawing-actions">
                        @if (canSubmit)
                        {
                            <button class="dtd-btn dtd-btn-primary" @onclick="SubmitDrawingAsync" disabled="@_submitting" aria-label="Submit Drawing">
                                @if (_submitting)
                                {
                                    <span>Submitting…</span>
                                }
                                else
                                {
                                    <span>✅ Submit</span>
                                }
                            </button>
                        }

                        <button class="dtd-btn dtd-btn-secondary" @onclick="MarkDoneAsync" disabled="@(_submitting || mySubmitted == 0)" aria-label="Done for this round">
                            ⏭ Done
                        </button>
                    </div>
                </div>

                @if (_errorMessage is not null)
                {
                    <p class="dtd-drawing-error">@_errorMessage</p>
                }
            }
            else
            {
                <div class="dtd-drawing-waiting">
                    <p>✅ You're done! Waiting for the others…</p>
                </div>
            }
        </div>
    }

</div>

