@page "/room/drawn-to-dress/{ObfuscatedRoomCode}"

@inherits DisposableComponent

<PageTitle>Drawn To Dress</PageTitle>

<HeadContent>
    <link rel="stylesheet" href="_content/KnockBox.DrawnToDress/css/dtd-shared.css" />
</HeadContent>

<DtdAriaAnnouncer @ref="_announcer" />

<div class="content dtd-game" role="main">
    <h1 class="dtd-sr-only">Drawn To Dress Game</h1>

    @if (GameState is null)
    {
        <div>Loading...</div>
    }
    else if (GameState.IsJoinable)
    {
        <LobbyPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.ThemeSelection)
    {
        <ThemeSelectionPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.Drawing)
    {
        <DrawingPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.PoolReveal
             && (GameState.Context?.CurrentOutfitRound ?? 1) > 1)
    {
        <PoolRevealPhase GameState="GameState"
                         HeadingText="@($"Get Ready for Round {GameState.Context!.CurrentOutfitRound}!")"
                         SubText="@($"Outfit {GameState.Context!.CurrentOutfitRound} building starts in\u2026")" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.PoolReveal)
    {
        <PoolRevealPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.OutfitBuilding)
    {
        <OutfitBuildingPhase GameState="GameState" OutfitRound="@(GameState.Context?.CurrentOutfitRound ?? 1)" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.OutfitCustomization)
    {
        <OutfitCustomizationPhase GameState="GameState" OutfitRound="@(GameState.Context?.CurrentOutfitRound ?? 1)" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.OutfitDistinctnessResolution)
    {
        <OutfitDistinctnessResolutionPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.Voting)
    {
        <VotingPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.CoinFlip)
    {
        <CoinFlipPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.VotingRoundResults)
    {
        <VotingRoundResultsPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.DrawnToDress.Services.State.Games.GamePhase.Results)
    {
        <FinalResultsPhase GameState="GameState" />
    }
    else
    {
        <div class="card">
            <p>Phase: @GameState.Phase</p>
            <p>Game in progress — more content coming soon.</p>
        </div>
    }
</div>

