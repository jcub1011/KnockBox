@page "/admin"
@layout AdminLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using KnockBox.Core.Plugins
@using KnockBox.Services.Logic.Admin
@using KnockBox.Services.Logic.Games.Shared
@implements IDisposable
@inject IAdminMetricsService Metrics
@inject ILobbyService LobbyService
@inject IEnumerable<IGameModule> GameModules

<PageTitle>Admin - Dashboard</PageTitle>

<h1 class="admin-h1">Dashboard</h1>

<div class="admin-card-grid">
    <div class="admin-card">
        <div class="admin-card-label">Active Users</div>
        <div class="admin-card-value">@Metrics.ActiveCircuitCount</div>
        <div class="admin-card-sub">Connected Blazor circuits</div>
    </div>
    <div class="admin-card">
        <div class="admin-card-label">Active Lobbies</div>
        <div class="admin-card-value">@_totalLobbies</div>
        <div class="admin-card-sub">Across all games</div>
    </div>
    <div class="admin-card">
        <div class="admin-card-label">Uptime</div>
        <div class="admin-card-value">@FormatUptime(Metrics.Uptime)</div>
        <div class="admin-card-sub">Since @Metrics.StartedAtUtc.ToString("u")</div>
    </div>
    <div class="admin-card">
        <div class="admin-card-label">Plugins Loaded</div>
        <div class="admin-card-value">@GameModules.Count()</div>
        <div class="admin-card-sub">Discovered game modules</div>
    </div>
</div>

<h2 class="admin-h2">Games running per type</h2>
<table class="admin-table">
    <thead>
        <tr>
            <th>Game</th>
            <th>Route</th>
            <th style="text-align:right">Active lobbies</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var row in BuildGameRows())
        {
            <tr>
                <td>@row.Name</td>
                <td><code>@row.Route</code></td>
                <td style="text-align:right">@row.Count</td>
            </tr>
        }
    </tbody>
</table>

<h2 class="admin-h2">Bound addresses</h2>
<table class="admin-table">
    <tbody>
        @if (Metrics.BoundAddresses.Count == 0)
        {
            <tr><td>(not reported yet)</td></tr>
        }
        else
        {
            @foreach (var address in Metrics.BoundAddresses)
            {
                <tr><td><code>@address</code></td></tr>
            }
        }
    </tbody>
</table>

@code {
    // Auto-refresh at a gentle cadence so metrics stay current without
    // spamming the server. A short-period CancellationTokenSource covers
    // disposal cleanly.
    private readonly PeriodicTimer _timer = new(TimeSpan.FromSeconds(3));
    private CancellationTokenSource? _cts;
    private int _totalLobbies;

    protected override void OnInitialized()
    {
        _cts = new CancellationTokenSource();
        _ = RunRefreshLoop(_cts.Token);
    }

    private async Task RunRefreshLoop(CancellationToken ct)
    {
        try
        {
            while (await _timer.WaitForNextTickAsync(ct))
            {
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { /* expected on dispose */ }
    }

    private IEnumerable<GameRow> BuildGameRows()
    {
        var counts = LobbyService.GetLobbyCountsByRoute();
        _totalLobbies = counts.Values.Sum();

        // Union all loaded modules with the live counts so games with zero
        // active lobbies still appear -- an operator scanning the page
        // should see every game, not just the busy ones.
        return GameModules
            .OrderBy(m => m.Name)
            .Select(m =>
            {
                counts.TryGetValue(m.RouteIdentifier, out var c);
                return new GameRow(m.Name, m.RouteIdentifier, c);
            });
    }

    private static string FormatUptime(TimeSpan uptime)
    {
        if (uptime.TotalDays >= 1)
            return $"{(int)uptime.TotalDays}d {uptime.Hours}h {uptime.Minutes}m";
        if (uptime.TotalHours >= 1)
            return $"{uptime.Hours}h {uptime.Minutes}m";
        if (uptime.TotalMinutes >= 1)
            return $"{uptime.Minutes}m {uptime.Seconds}s";
        return $"{uptime.Seconds}s";
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
        _timer.Dispose();
    }

    private readonly record struct GameRow(string Name, string Route, int Count);
}
