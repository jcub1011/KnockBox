@using KnockBox.Core.Services.State.Games.Shared
@using KnockBox.Services.Logic.Games.DrawnToDress.FSM
@using KnockBox.Services.Logic.Games.DrawnToDress.FSM.States
@using KnockBox.Services.State.Games.DrawnToDress

@if (GameState.PhaseDeadlineUtc.HasValue &&
     GameState.Context?.Fsm?.CurrentState is ITimedDrawnToDressGameState timed &&
     (GameState.Config.EnableTimer || !timed.IsTimerOptional))
{
    var remaining = timed.GetRemainingTime(GameState.Context!, DateTimeOffset.UtcNow);
    if (remaining.IsSuccess && remaining.Value.TotalSeconds >= 0)
    {
        var endTime = DateTimeOffset.UtcNow.Add(remaining.Value);
        var duration = GetTotalDuration();

        <CountdownClock EndTimeUtc="endTime" Duration="duration" Context="countdown">
            @{
                var secs = (int)Math.Max(0, Math.Ceiling(countdown.RemainingSeconds));
            }
            <div class="dtd-timer @(secs <= 10 ? "dtd-timer-urgent" : "")"
                 role="timer"
                 aria-label="@secs seconds remaining">
                @secs s
            </div>
        </CountdownClock>
    }
}

@code {
    [Parameter, EditorRequired]
    public DrawnToDressGameState GameState { get; set; } = default!;

    private TimeSpan GetTotalDuration() => GameState.Phase switch
    {
        GamePhase.ThemeSelection => TimeSpan.FromSeconds(GameState.Config.ThemeAnnouncementTimeSec),
        GamePhase.Drawing => TimeSpan.FromSeconds(GameState.Config.DrawingTimeSec),
        GamePhase.PoolReveal => TimeSpan.FromSeconds(GameState.Config.PoolRevealTimeSec),
        GamePhase.OutfitBuilding => TimeSpan.FromSeconds(GameState.Config.OutfitBuildingTimeSec),
        GamePhase.OutfitCustomization => TimeSpan.FromSeconds(GameState.Config.OutfitCustomizationTimeSec),
        GamePhase.Voting => TimeSpan.FromSeconds(GameState.Config.VotingTimeSec),
        GamePhase.VotingRoundResults => TimeSpan.FromSeconds(GameState.Config.VotingRoundResultsTimeSec),
        GamePhase.CoinFlip => TimeSpan.FromSeconds(GameState.Config.CoinFlipTimeSec),
        _ => TimeSpan.FromSeconds(30)
    };
}
