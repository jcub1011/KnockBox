@using KnockBox.Core.Services.State.Games.Shared
@using KnockBox.Services.Logic.Games.DrawnToDress.FSM
@using KnockBox.Services.Logic.Games.DrawnToDress.FSM.States
@using KnockBox.Services.State.Games.DrawnToDress
@using KnockBox.Services.State.Games.DrawnToDress.Data
@using KnockBox.Services.State.Users

@{
    bool isHost = UserService.CurrentUser?.Id == GameState.Host.Id;
    string? myId = UserService.CurrentUser?.Id;

    int roundIndex = GameState.CurrentVotingRoundIndex;
    VotingRound? currentRound = roundIndex < GameState.VotingRounds.Count
        ? GameState.VotingRounds[roundIndex]
        : null;

    int totalConfiguredRounds = GameState.Config.VotingRounds;
}

<div class="dtd-voting">

    <!-- ── Header ────────────────────────────────────────────────────────── -->
    <div class="dtd-voting-header">
        <div class="dtd-voting-phase-badge">
            <span class="dtd-voting-phase-icon">🗳</span>
            <span class="dtd-voting-phase-name">Voting Round @(roundIndex + 1) of @totalConfiguredRounds</span>
        </div>

        @if (GameState.PhaseDeadlineUtc.HasValue &&
             GameState.Context?.Fsm?.CurrentState is ITimedGameState<DrawnToDressGameContext, DrawnToDressCommand> timedState)
        {
            var remaining = timedState.GetRemainingTime(GameState.Context!, DateTimeOffset.UtcNow);
            if (remaining.IsSuccess)
            {
                var secs = (int)Math.Max(0, Math.Ceiling(remaining.Value.TotalSeconds));
                <div class="dtd-voting-timer @(secs <= 10 ? "dtd-voting-timer-urgent" : "")">
                    ⏱ @secs s
                </div>
            }
        }
    </div>

    @if (currentRound is null)
    {
        <p>Preparing matchups...</p>
    }
    else
    {
        <!-- ── Host view ─────────────────────────────────────────────────── -->
        @if (isHost)
        {
            <div class="dtd-voting-host-panel">
                <h3>Matchup Progress</h3>
                @foreach (var matchup in currentRound.Matchups)
                {
                    int voteCount = GameState.Votes.Values.Count(v => v.MatchupId == matchup.Id);
                    <div class="dtd-voting-matchup-status">
                        <span>@GetEntrantDisplayName(matchup.EntrantAId) vs @GetEntrantDisplayName(matchup.EntrantBId)</span>
                        <span class="dtd-voting-vote-count">@voteCount vote(s)</span>
                    </div>
                }
            </div>
        }

        <!-- ── Player view ───────────────────────────────────────────────── -->
        @if (!isHost)
        {
            @foreach (var matchup in currentRound.Matchups)
            {
                bool isCompeting = IsCompetingInMatchup(matchup);
                bool alreadySubmitted = HasAlreadySubmittedVotesForMatchup(matchup.Id);

                <div class="dtd-voting-matchup-card">
                    @if (isCompeting)
                    {
                        <div class="dtd-voting-competing">
                            <p>You're competing in this matchup!</p>
                        </div>
                    }
                    else if (alreadySubmitted)
                    {
                        <div class="dtd-voting-submitted">
                            <p>✅ Votes submitted for this matchup.</p>
                        </div>
                    }
                    else
                    {
                        <!-- Side-by-side outfit display -->
                        <div class="dtd-voting-matchup-outfits">
                            @{
                                var outfitA = GetEntrantOutfit(matchup.EntrantAId);
                                var outfitB = GetEntrantOutfit(matchup.EntrantBId);
                            }

                            <div class="dtd-voting-entrant">
                                <h4>@GetEntrantDisplayName(matchup.EntrantAId)</h4>
                                @if (outfitA is not null)
                                {
                                    <div class="dtd-voting-outfit-items">
                                        @foreach (var ct in GameState.Config.ClothingTypes)
                                        {
                                            @if (outfitA.SelectedItemsByType.TryGetValue(ct.Id, out var itemId)
                                                && GameState.ClothingPool.TryGetValue(itemId, out var item))
                                            {
                                                <div class="dtd-voting-outfit-item">
                                                    <span class="dtd-voting-item-label">@ct.DisplayName</span>
                                                    @if (SafeSvgContent(item.SvgContent) is string safeSvg)
                                                    {
                                                        <svg class="dtd-voting-item-preview" viewBox="0 0 800 400"
                                                             preserveAspectRatio="xMidYMid meet"
                                                             xmlns="http://www.w3.org/2000/svg">
                                                            @((MarkupString)safeSvg)
                                                        </svg>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(outfitA.Customization.OutfitName))
                                    {
                                        <p class="dtd-voting-outfit-name">"@outfitA.Customization.OutfitName"</p>
                                    }
                                }
                            </div>

                            <div class="dtd-voting-vs">VS</div>

                            <div class="dtd-voting-entrant">
                                <h4>@GetEntrantDisplayName(matchup.EntrantBId)</h4>
                                @if (outfitB is not null)
                                {
                                    <div class="dtd-voting-outfit-items">
                                        @foreach (var ct in GameState.Config.ClothingTypes)
                                        {
                                            @if (outfitB.SelectedItemsByType.TryGetValue(ct.Id, out var itemId)
                                                && GameState.ClothingPool.TryGetValue(itemId, out var item))
                                            {
                                                <div class="dtd-voting-outfit-item">
                                                    <span class="dtd-voting-item-label">@ct.DisplayName</span>
                                                    @if (SafeSvgContent(item.SvgContent) is string safeSvg)
                                                    {
                                                        <svg class="dtd-voting-item-preview" viewBox="0 0 800 400"
                                                             preserveAspectRatio="xMidYMid meet"
                                                             xmlns="http://www.w3.org/2000/svg">
                                                            @((MarkupString)safeSvg)
                                                        </svg>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(outfitB.Customization.OutfitName))
                                    {
                                        <p class="dtd-voting-outfit-name">"@outfitB.Customization.OutfitName"</p>
                                    }
                                }
                            </div>
                        </div>

                        <!-- Voting criteria buttons -->
                        <div class="dtd-voting-criteria">
                            @foreach (var criterion in GameState.Config.VotingCriteria)
                            {
                                var key = (matchup.Id, criterion.Id);
                                _selectedVotes.TryGetValue(key, out var selected);

                                <div class="dtd-voting-criterion-row">
                                    <span class="dtd-voting-criterion-label">@criterion.DisplayName</span>
                                    <div class="dtd-voting-criterion-buttons">
                                        <button class="dtd-btn dtd-btn-vote @(selected == matchup.EntrantAId ? "dtd-btn-vote-selected" : "")"
                                                @onclick="() => SelectVote(matchup.Id, criterion.Id, matchup.EntrantAId)">
                                            Choose A
                                        </button>
                                        <button class="dtd-btn dtd-btn-vote @(selected == matchup.EntrantBId ? "dtd-btn-vote-selected" : "")"
                                                @onclick="() => SelectVote(matchup.Id, criterion.Id, matchup.EntrantBId)">
                                            Choose B
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>

                        <div class="dtd-voting-actions">
                            <button class="dtd-btn dtd-btn-primary"
                                    @onclick="() => SubmitVotesForMatchupAsync(matchup.Id)"
                                    disabled="@(!AllCriteriaVotedForMatchup(matchup.Id) || _submitting)">
                                Submit Vote
                            </button>
                        </div>
                    }
                </div>
            }
        }
    }

    @if (_errorMessage is not null)
    {
        <p class="dtd-voting-error">@_errorMessage</p>
    }

</div>
