@using KnockBox.Services.Logic.Games.DrawnToDress
@using KnockBox.Services.Logic.Games.DrawnToDress.FSM
@using KnockBox.Services.State.Games.DrawnToDress
@using KnockBox.Services.State.Games.DrawnToDress.Data
@using KnockBox.Services.State.Users

@{
    bool isHost = UserService.CurrentUser?.Id == GameState.Host.Id;
    var leaderboard = GameState.Leaderboard;
    var winner = leaderboard.FirstOrDefault(e => e.Rank == 1);
}

<div class="dtd-final-results">

    <!-- ── Winner celebration ──────────────────────────────────────────── -->
    @if (winner is not null)
    {
        <div class="dtd-final-results-winner">
            <div class="dtd-final-results-trophy">1st</div>
            <h2 class="dtd-final-results-winner-name">@winner.DisplayName</h2>
            <p class="dtd-final-results-winner-score">@winner.TotalScore.ToString("0.#") points</p>
        </div>
    }

    <!-- ── Leaderboard table ───────────────────────────────────────────── -->
    <div class="dtd-final-results-leaderboard">
        <h3>Final Standings</h3>
        <table class="dtd-final-results-table">
            <thead>
                <tr>
                    <th>Rank</th>
                    <th>Player</th>
                    <th>Score</th>
                    <th>W/L</th>
                    <th>MW</th>
                    <th>Bonus</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in leaderboard)
                {
                    bool isWinner = entry.Rank == 1;
                    <tr class="@(isWinner ? "dtd-final-results-row-winner" : "")">
                        <td class="dtd-final-results-rank">@entry.Rank</td>
                        <td class="dtd-final-results-name">@entry.DisplayName</td>
                        <td class="dtd-final-results-pts">@entry.TotalScore.ToString("0.#")</td>
                        <td class="dtd-final-results-wl">@entry.Wins–@entry.Losses</td>
                        <td class="dtd-final-results-mw">@entry.MatchupWins.ToString("0.#")</td>
                        <td class="dtd-final-results-bonus">@entry.BonusPoints</td>
                        <td class="dtd-final-results-tiebreak">
                            @if (entry.TiebreakMethod == "matchup_wins")
                            {
                                <span class="dtd-final-results-tiebreak-label" title="Tie broken by matchup wins">Won via matchup wins</span>
                            }
                            else if (entry.TiebreakMethod == "coin_flip")
                            {
                                <span class="dtd-final-results-tiebreak-label dtd-final-results-tiebreak-flip" title="Tie broken by coin flip">Won via coin flip</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ── Actions ─────────────────────────────────────────────────────── -->
    <div class="dtd-final-results-actions">
        @if (isHost)
        {
            <button class="dtd-btn dtd-btn-primary"
                    @onclick="PlayAgainAsync"
                    disabled="@_submitting">
                Play Again
            </button>
        }
        <button class="dtd-btn dtd-btn-secondary"
                @onclick="ReturnToMenuAsync"
                disabled="@_submitting">
            Return to Menu
        </button>
    </div>

    @if (_errorMessage is not null)
    {
        <p class="dtd-final-results-error">@_errorMessage</p>
    }

</div>
