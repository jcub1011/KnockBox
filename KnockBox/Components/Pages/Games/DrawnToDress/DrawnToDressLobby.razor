@page "/room/drawn-to-dress/{ObfuscatedRoomCode}"

@inherits DisposableComponent

<PageTitle>Drawn To Dress</PageTitle>

<div class="content">
    @if (GameState is null)
    {
        <div>Loading...</div>
    }
    else if (GameState.IsJoinable)
    {
        <LobbyPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.ThemeSelection)
    {
        <ThemeSelectionPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.Drawing)
    {
        <DrawingPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.PoolReveal
             && (GameState.Context?.CurrentOutfitRound ?? 1) > 1)
    {
        <PoolRevealPhase GameState="GameState"
                         HeadingText="@($"Get Ready for Round {GameState.Context!.CurrentOutfitRound}!")"
                         SubText="@($"Outfit {GameState.Context!.CurrentOutfitRound} building starts in\u2026")" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.PoolReveal)
    {
        <PoolRevealPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.OutfitBuilding)
    {
        <OutfitBuildingPhase GameState="GameState" OutfitRound="@(GameState.Context?.CurrentOutfitRound ?? 1)" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.OutfitCustomization)
    {
        <OutfitCustomizationPhase GameState="GameState" OutfitRound="@(GameState.Context?.CurrentOutfitRound ?? 1)" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.Voting)
    {
        <VotingPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.CoinFlip)
    {
        <CoinFlipPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.VotingRoundResults)
    {
        <VotingRoundResultsPhase GameState="GameState" />
    }
    else if (GameState.Phase == KnockBox.Services.State.Games.DrawnToDress.GamePhase.Results)
    {
        <FinalResultsPhase GameState="GameState" />
    }
    else
    {
        <div class="card">
            <p>Phase: @GameState.Phase</p>
            <p>Game in progress — more content coming soon.</p>
        </div>
    }
</div>
