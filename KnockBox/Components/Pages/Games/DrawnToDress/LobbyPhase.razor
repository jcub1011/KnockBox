@using KnockBox.Services.State.Users
@using KnockBox.Services.State.Games.DrawnToDress
@using KnockBox.Services.State.Games.DrawnToDress.Data

<div class="dtd-lobby">
    @{
        bool isHost = UserService.CurrentUser?.Id == GameState.Host.Id;
        // Players property excludes the host. The host cannot participate in the game,
        // so the player count only reflects active participants.
        int playerCount = GameState.Players.Count;
        bool belowMinimum = playerCount < DrawnToDressConfig.RecommendedMinimumPlayers;
    }

    <div class="dtd-lobby-main">
        <h2 class="dtd-lobby-title">👗 Drawn To Dress</h2>
        <p class="dtd-lobby-subtitle">Waiting for players...</p>

        <h4 class="dtd-section-title">Players (@playerCount)</h4>
        <div class="dtd-player-list">
            @* Host is always first *@
            <div class="dtd-player dtd-player-host @(GameState.Host.Id == UserService.CurrentUser?.Id ? "dtd-player-me" : "")">
                <span class="dtd-player-avatar">👑</span>
                <span class="dtd-player-name">@GameState.Host.Name</span>
                <span class="dtd-host-badge">HOST</span>
            </div>

            @foreach (var player in GameState.Players)
            {
                bool isMe = player.Id == UserService.CurrentUser?.Id;
                if (isHost)
                {
                    <button class="dtd-player dtd-player-kick @(isMe ? "dtd-player-me" : "")"
                            @onclick="() => KickPlayer(player.Id)"
                            title="Click to kick @player.Name">
                        <span class="dtd-player-avatar">🎨</span>
                        <span class="dtd-player-name">@player.Name</span>
                        <span class="dtd-kick-hint">✕ Kick</span>
                    </button>
                }
                else
                {
                    <div class="dtd-player @(isMe ? "dtd-player-me" : "")">
                        <span class="dtd-player-avatar">🎨</span>
                        <span class="dtd-player-name">@player.Name</span>
                    </div>
                }
            }
        </div>

        @if (isHost)
        {
            @if (belowMinimum)
            {
                <p class="dtd-warning">
                    ⚠️ Recommended minimum is @DrawnToDressConfig.RecommendedMinimumPlayers players.
                    You can still start, but gameplay may feel limited.
                </p>
            }
            <button class="dtd-btn dtd-btn-primary dtd-btn-lg" @onclick="StartGame">
                🎨 Start Game
            </button>
        }
        else
        {
            <p class="dtd-waiting-text">Waiting for the host to start...</p>
        }
    </div>

    @if (isHost)
    {
        <button class="dtd-settings-toggle-btn" @onclick="ToggleSettings" title="Game Settings">
            ⚙️
        </button>

        @if (SettingsOpen)
        {
            <div class="dtd-settings-backdrop" @onclick="ToggleSettings"></div>
        }
        <div class="dtd-settings-drawer @(SettingsOpen ? "dtd-settings-drawer-open" : "")">
            <div class="dtd-settings-header">
                <h3 class="dtd-settings-title">⚙️ Game Settings</h3>
                <button class="dtd-settings-close-btn" @onclick="ToggleSettings" title="Close">✕</button>
            </div>
            <div class="dtd-settings-body">

                <!-- ── Drawing ──────────────────────────────────────────── -->
                <h4 class="dtd-settings-section">🖊️ Drawing</h4>
                <div class="dtd-settings-grid">
                    <label class="dtd-setting-label">
                        Drawing Time (seconds):
                        <input type="number" min="30" class="dtd-setting-input"
                               @bind="EditConfig.DrawingTimeSec" @bind:after="ApplyConfig" />
                    </label>
                    <label class="dtd-setting-label">
                        Theme Announcement Time (seconds):
                        <input type="number" min="5" class="dtd-setting-input"
                               @bind="EditConfig.ThemeAnnouncementTimeSec" @bind:after="ApplyConfig" />
                    </label>
                    <label class="dtd-setting-label dtd-setting-label-row" title="Players can keep sketching while outfit building is active">
                        <span>Allow Sketching During Outfit Building:</span>
                        <input type="checkbox" class="dtd-setting-checkbox"
                               @bind="EditConfig.AllowSketchingDuringOutfitBuilding" @bind:after="ApplyConfig" />
                    </label>
                </div>

                <!-- ── Theme ────────────────────────────────────────────── -->
                <h4 class="dtd-settings-section">🎭 Theme</h4>
                <div class="dtd-settings-grid">
                    <label class="dtd-setting-label">
                        Theme Source:
                        <select class="dtd-setting-select" @bind="EditConfig.ThemeSource" @bind:after="ApplyConfig">
                            @foreach (var source in Enum.GetValues<ThemeSource>())
                            {
                                <option value="@source">@source</option>
                            }
                        </select>
                    </label>
                </div>

                <!-- ── Outfit Building ──────────────────────────────────── -->
                <h4 class="dtd-settings-section">👗 Outfit Building</h4>
                <div class="dtd-settings-grid">
                    <label class="dtd-setting-label">
                        Outfit Building Time (seconds):
                        <input type="number" min="30" class="dtd-setting-input"
                               @bind="EditConfig.OutfitBuildingTimeSec" @bind:after="ApplyConfig" />
                    </label>
                    <label class="dtd-setting-label">
                        Outfit Customization Time (seconds):
                        <input type="number" min="15" class="dtd-setting-input"
                               @bind="EditConfig.OutfitCustomizationTimeSec" @bind:after="ApplyConfig" />
                    </label>
                    <label class="dtd-setting-label dtd-setting-label-row" title="Players may reuse their own drawn items in their outfit">
                        <span>Allow Reuse of Own Items:</span>
                        <input type="checkbox" class="dtd-setting-checkbox"
                               @bind="EditConfig.AllowReuseOwnItems" @bind:after="ApplyConfig" />
                    </label>
                    <label class="dtd-setting-label dtd-setting-label-row" title="Each outfit slot must contain a unique item">
                        <span>Require Distinct Items Per Slot:</span>
                        <input type="checkbox" class="dtd-setting-checkbox"
                               @bind="EditConfig.RequireDistinctItemsPerSlot" @bind:after="ApplyConfig" />
                    </label>
                </div>

                <!-- ── Voting ────────────────────────────────────────────── -->
                <h4 class="dtd-settings-section">🗳️ Voting</h4>
                <div class="dtd-settings-grid">
                    <label class="dtd-setting-label">
                        Voting Time (seconds):
                        <input type="number" min="15" class="dtd-setting-input"
                               @bind="EditConfig.VotingTimeSec" @bind:after="ApplyConfig" />
                    </label>
                    <label class="dtd-setting-label dtd-setting-label-row" title="Reveal who created each outfit to voters">
                        <span>Show Creator During Voting:</span>
                        <input type="checkbox" class="dtd-setting-checkbox"
                               @bind="EditConfig.ShowCreatorDuringVoting" @bind:after="ApplyConfig" />
                    </label>
                </div>

                <!-- ── Tournament ────────────────────────────────────────── -->
                <h4 class="dtd-settings-section">🏆 Tournament</h4>
                <div class="dtd-settings-grid">
                    <label class="dtd-setting-label">
                        Voting Rounds:
                        <input type="number" min="1" class="dtd-setting-input"
                               @bind="EditConfig.VotingRounds" @bind:after="ApplyConfig" />
                    </label>
                    <label class="dtd-setting-label">
                        Bonus Points for Complete Outfit:
                        <input type="number" min="0" class="dtd-setting-input"
                               @bind="EditConfig.BonusPointsForCompleteOutfit" @bind:after="ApplyConfig" />
                    </label>
                </div>

                <!-- ── Host / Connectivity ───────────────────────────────── -->
                <h4 class="dtd-settings-section">🔌 Connectivity</h4>
                <div class="dtd-settings-grid">
                    <label class="dtd-setting-label">
                        Host Disconnect Timeout (seconds):
                        <input type="number" min="30" class="dtd-setting-input"
                               @bind="EditConfig.HostDisconnectTimeoutSec" @bind:after="ApplyConfig" />
                    </label>
                </div>

            </div>
        </div>
    }
</div>
