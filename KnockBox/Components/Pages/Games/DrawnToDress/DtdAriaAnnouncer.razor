@implements IDisposable

<div class="dtd-sr-only" aria-live="polite" aria-atomic="true">
    @_currentMessage
</div>

@code {
    private string _currentMessage = "";
    private CancellationTokenSource? _clearCts;
    private bool _disposed;

    public void Announce(string message)
    {
        _clearCts?.Cancel();
        _clearCts?.Dispose();
        _clearCts = new CancellationTokenSource();
        var token = _clearCts.Token;

        // Clear first so repeated identical messages still get announced.
        _currentMessage = "";
        InvokeAsync(StateHasChanged);

        _ = Task.Delay(50, token).ContinueWith(_ =>
        {
            if (_disposed) return;
            _currentMessage = message;
            InvokeAsync(StateHasChanged);
        }, token, TaskContinuationOptions.OnlyOnRanToCompletion, TaskScheduler.Default);

        // Auto-clear after 5 seconds.
        _ = Task.Delay(5000, token).ContinueWith(_ =>
        {
            if (_disposed) return;
            _currentMessage = "";
            InvokeAsync(StateHasChanged);
        }, token, TaskContinuationOptions.OnlyOnRanToCompletion, TaskScheduler.Default);
    }

    public void Dispose()
    {
        _disposed = true;
        _clearCts?.Cancel();
        _clearCts?.Dispose();
    }
}
