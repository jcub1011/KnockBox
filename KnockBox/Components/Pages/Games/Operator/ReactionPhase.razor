@using KnockBox.Operator.Models

<div class="op-setup">
    <div class="op-reaction-content">
        @if (IsTargeted)
        {
            <h2 class="op-phase-title">&#x26A0;&#xFE0F; YOU ARE BEING TARGETED!</h2>
            <p class="op-waiting-text">Someone played an action against you. Use a shield or take the hit.</p>

            var shields = GetShields();
            var hotPotatoes = GetHotPotatoes();

            @if (shields.Count > 0 || (hotPotatoes.Count > 0 && CanRedirectHotPotato))
            {
                <div class="op-setup-choices">
                    @foreach (var shield in shields)
                    {
                        <div class="op-choice-btn" @onclick="() => PlayShield(shield.Id)">
                            <div class="op-card-icon">&#x1F6E1;&#xFE0F;</div>
                            <div class="op-choice-label">USE SHIELD</div>
                        </div>
                    }
                    @if (hotPotatoes.Count > 0 && CanRedirectHotPotato)
                    {
                        @foreach (var hp in hotPotatoes)
                        {
                            <div class="op-choice-btn" @onclick="() => StartRedirect(hp.Id)">
                                <div class="op-card-icon">&#x1F954;</div>
                                <div class="op-choice-label">REDIRECT</div>
                            </div>
                        }
                    }
                </div>

                @if (_redirectingWithCardId != null)
                {
                    <div style="margin-top: 20px; text-align: center;">
                        <p class="op-waiting-text">Select a player to redirect Hot Potato to:</p>
                        <div class="op-setup-choices">
                            @foreach (var player in GameState.Players.Where(p => p.Id != UserService.CurrentUser?.Id))
                            {
                                <div class="op-choice-btn" @onclick="() => RedirectHotPotato(player.Id)">
                                    <div class="op-choice-label">@player.Name</div>
                                </div>
                            }
                        </div>
                        <button class="op-btn op-btn-secondary" style="margin-top: 10px;" @onclick="CancelRedirect">CANCEL</button>
                    </div>
                }

                <div style="margin-top: 20px; text-align: center;">
                    <button class="op-btn op-btn-danger" @onclick="Pass">TAKE THE HIT (PASS)</button>
                </div>
            }
            else
            {
                <div class="op-no-shields" style="text-align: center;">
                    <p class="op-waiting-text">You have no shields available.</p>
                    <button class="op-btn op-btn-primary" @onclick="Pass">CONTINUE</button>
                </div>
            }
        }
        else
        {
            <div class="op-reaction-waiting">
                <h2 class="op-phase-title">Waiting for reaction...</h2>
                <p class="op-waiting-text">Waiting for @(GameState.Players.FirstOrDefault(p => p.Id == GameState.ReactionTargetPlayerId)?.Name ?? "the target") to respond.</p>
            </div>
        }
    </div>
</div>
