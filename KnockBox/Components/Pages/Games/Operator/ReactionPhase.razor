@using KnockBox.Operator.Models

<div class="op-reaction-overlay">
    <div class="op-reaction-backdrop"></div>
    <div class="op-reaction-panel">
        @if (IsTargeted)
        {
            var ltCards = GetPendingLiabilityTransferCards();

            <div class="op-reaction-alert-icon">&#x26A0;&#xFE0F;</div>
            <h2 class="op-reaction-title">YOU ARE BEING TARGETED!</h2>
            <p class="op-reaction-subtitle">
                <strong>@GetAttackerName()</strong> played <strong>@GetActionDescription()</strong> against you!
            </p>

            <div class="op-reaction-player-status">
                <div class="op-status-item">
                    <span class="op-status-label">YOUR SCORE:</span>
                    <span class="op-status-value">@(CurrentPlayerState?.CurrentPoints.ToString("F1") ?? "0.0")</span>
                </div>
                <div class="op-status-item">
                    <span class="op-status-label">YOUR OPERATOR:</span>
                    <span class="op-status-value">@(CurrentPlayerState?.ActiveOperator.ToSymbol() ?? "+")</span>
                </div>
            </div>

            @if (GameState.PendingHotPotatoCards.Count > 0)
            {
                decimal totalVal = 0;
                foreach (var card in GameState.PendingHotPotatoCards.OfType<NumberCard>())
                {
                    totalVal = totalVal * 10 + card.NumberValue;
                }

                <div class="op-hp-preview">
                    <div class="op-hp-preview-label">POTENTIAL IMPACT:</div>
                    <div class="op-hp-preview-value">@totalVal</div>
                    <div class="op-hp-preview-hint">Cards in this set will be applied to your score using your current operator.</div>
                </div>
            }

            @if (ltCards.Count > 0)
            {
                <div class="op-lt-preview">
                    <div class="op-lt-preview-label">INCOMING CARDS:</div>
                    <div class="op-lt-preview-cards">
                        @foreach (var card in ltCards)
                        {
                            <div class="op-lt-preview-card">@card.NumberValue</div>
                        }
                    </div>
                    <div class="op-lt-preview-hint">These cards will be added to your hand if you don't block.</div>
                </div>
            }

            var reactionCards = GetPotentialReactionCards();

            @if (reactionCards.Count > 0)
            {
                <div class="op-reaction-actions">
                    @foreach (var card in reactionCards)
                    {
                        @if (card is ShieldCard shield)
                        {
                            <div class="op-reaction-action-btn shield-btn" @onclick="() => PlayShield(shield.Id)">
                                <div class="op-reaction-action-icon">&#x1F6E1;&#xFE0F;</div>
                                <div class="op-reaction-action-label">USE SHIELD</div>
                            </div>
                        }
                        else if (card is HotPotatoCard hp && CanRedirectHotPotato)
                        {
                            <div class="op-reaction-action-btn redirect-btn" @onclick="() => StartRedirect(hp.Id)">
                                <div class="op-reaction-action-icon">&#x1F954;</div>
                                <div class="op-reaction-action-label">REDIRECT</div>
                            </div>
                        }
                    }
                </div>

                @if (_redirectingWithCardId != null)
                {
                    <div class="op-redirect-section">
                        <p class="op-waiting-text">Select a player to redirect Hot Potato to:</p>
                        <div class="op-redirect-players">
                            @foreach (var player in GameState.Players.Where(p => p.Id != UserService.CurrentUser?.Id))
                            {
                                <button class="op-redirect-player-btn" @onclick="() => RedirectHotPotato(player.Id)">
                                    @player.Name
                                </button>
                            }
                        </div>
                        <button class="op-btn op-btn-secondary" @onclick="CancelRedirect">CANCEL</button>
                    </div>
                }

                <div class="op-reaction-pass">
                    <button class="op-btn op-btn-danger" @onclick="Pass">TAKE THE HIT (PASS)</button>
                </div>
            }
            else
            {
                <div class="op-no-shields">
                    <p class="op-waiting-text">You have no reaction cards available.</p>
                    <button class="op-btn op-btn-primary" @onclick="Pass">CONTINUE</button>
                </div>
            }
        }
        else
        {
            <div class="op-reaction-waiting-content">
                <h2 class="op-reaction-title" style="font-size: 1.2rem;">Waiting for reaction...</h2>
                <p class="op-reaction-subtitle">
                    Waiting for <strong>@(GameState.Players.FirstOrDefault(p => p.Id == GameState.ReactionTargetPlayerId)?.Name ?? "the target")</strong> to respond.
                </p>
            </div>
        }
    </div>
</div>
