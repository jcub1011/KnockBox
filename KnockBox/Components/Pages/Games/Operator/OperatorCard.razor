@using KnockBox.Operator.Models

<div class="op-card @GetCardTypeClass() @(IsSelected ? "selected" : "") @(IsDisabled ? "disabled" : "") @(IsNew ? "op-card-new" : "") @(_showTooltip ? "tooltip-visible" : "")"
     style="@(IsNew ? $"animation-delay: {AnimationDelay * 150}ms" : "")"
     @onclick="HandleClick"
     @onpointerdown="OnPointerDown"
     @onpointerup="OnPointerUp"
     @onpointerleave="OnPointerLeave"
     @onmouseenter="OnMouseEnter"
     @onmouseleave="OnMouseLeave">
    <div class="op-card-inner">
        @if (Card is NumberCard)
        {
            <div class="op-card-value">@Card.CardIcon()</div>
            <div class="op-card-label">NUMBER</div>
        }
        else if (Card is KnockBox.Operator.Models.OperatorCard)
        {
            <div class="op-card-value">@Card.CardIcon()</div>
            <div class="op-card-label">OPERATOR</div>
        }
        else if (Card is ActionCard actCard)
        {
            <div class="op-card-icon">@Card.CardIcon()</div>
            <div class="op-card-name">@GetActionName(actCard)</div>
            <div class="op-card-label">ACTION</div>
        }
    </div>

    @if (_showTooltip)
    {
        <div class="op-card-tooltip">
            <div class="op-card-tooltip-title">@Card.TooltipName()</div>
            <div class="op-card-tooltip-desc">@Card.TooltipDescription()</div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public required Card Card { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public bool IsDisabled { get; set; }
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public int AnimationDelay { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private bool _showTooltip;
    private bool _longPressTriggered;
    private System.Threading.Timer? _longPressTimer;

    private string GetCardTypeClass() => Card.Type switch
    {
        CardType.Number => "op-card-num",
        CardType.Operator => "op-card-op",
        CardType.Action => "op-card-act",
        _ => ""
    };

    private string GetActionName(ActionCard card) => card.ActionValue switch
    {
        CardAction.Shield => "SHIELD",
        CardAction.LiabilityTransfer => "LIABILITY",
        CardAction.CookTheBooks => "COOK",
        CardAction.Comp => "COMP",
        CardAction.Steal => "STEAL",
        CardAction.HotPotato => "POTATO",
        CardAction.FlashFlood => "FLOOD",
        CardAction.HostileTakeover => "TAKEOVER",
        CardAction.Audit => "AUDIT",
        CardAction.MarketCrash => "CRASH",
        _ => "UNKNOWN"
    };

    // ── Hover (desktop) ──

    private void OnMouseEnter()
    {
        _showTooltip = true;
    }

    private void OnMouseLeave()
    {
        _showTooltip = false;
    }

    // ── Long press (mobile) ──

    private void OnPointerDown()
    {
        _longPressTriggered = false;
        _longPressTimer?.Dispose();
        _longPressTimer = new System.Threading.Timer(_ =>
        {
            _longPressTriggered = true;
            InvokeAsync(() =>
            {
                _showTooltip = true;
                StateHasChanged();
            });
        }, null, 500, System.Threading.Timeout.Infinite);
    }

    private void OnPointerUp()
    {
        _longPressTimer?.Dispose();
        _longPressTimer = null;

        if (_longPressTriggered)
        {
            _showTooltip = false;
            _longPressTriggered = false;
        }
    }

    private void OnPointerLeave()
    {
        _longPressTimer?.Dispose();
        _longPressTimer = null;
        _showTooltip = false;
        _longPressTriggered = false;
    }

    private async Task HandleClick()
    {
        if (_longPressTriggered || IsDisabled) return;
        await OnClick.InvokeAsync();
    }
}
