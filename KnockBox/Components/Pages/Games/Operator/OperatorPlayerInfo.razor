@implements IDisposable
@using KnockBox.Operator.Models

<div class="op-player-info @(IsActive ? "active" : "") @(IsTargetable ? "targetable" : "") @(IsTargeted ? "targeted" : "")" @onclick="OnClick">
    <div class="op-player-info-main">
        <span class="op-player-name">@Name</span>
        <div class="op-player-score-container">
            <div class="op-player-operator-card @(_opChanged ? "op-op-changed" : "")">
                <span class="op-player-operator-card-symbol">@GetOperatorSymbol()</span>
            </div>
            <span class="op-player-score @(_scoreChanged ? "op-score-changed" : "")">@Score.ToString("F1")</span>
        </div>
    </div>
    
    <div class="op-player-status-row">
        <div class="op-hand-size" title="Hand Size">🎴 @HandSize</div>
        @if (IsAudited) { <span class="op-status-badge" title="Audited">📝</span> }
    </div>

    @if (IsActive)
    {
        <div class="op-active-indicator">TURN</div>
    }
</div>

@code {
    [Parameter] public string Name { get; set; } = "";
    [Parameter] public decimal Score { get; set; }
    [Parameter] public CardOperator ActiveOperator { get; set; }
    [Parameter] public int HandSize { get; set; }
    [Parameter] public bool IsActive { get; set; }
    [Parameter] public bool IsAudited { get; set; }
    [Parameter] public bool IsTargetable { get; set; }
    [Parameter] public bool IsTargeted { get; set; }
    [Parameter] public EventCallback OnClick { get; set; }

    private decimal? _prevScore;
    private bool _scoreChanged;

    private CardOperator? _prevOp;
    private bool _opChanged;

    private CancellationTokenSource _cts = new();

    protected override void OnParametersSet()
    {
        if (_prevScore.HasValue && _prevScore.Value != Score)
        {
            _scoreChanged = true;
            var token = _cts.Token;
            _ = Task.Delay(1000, token).ContinueWith(_ =>
            {
                if (!token.IsCancellationRequested)
                {
                    _scoreChanged = false;
                    InvokeAsync(StateHasChanged);
                }
            }, token, TaskContinuationOptions.OnlyOnRanToCompletion, TaskScheduler.Default);
        }
        _prevScore = Score;

        if (_prevOp.HasValue && _prevOp.Value != ActiveOperator)
        {
            _opChanged = true;
            var token = _cts.Token;
            _ = Task.Delay(1000, token).ContinueWith(_ =>
            {
                if (!token.IsCancellationRequested)
                {
                    _opChanged = false;
                    InvokeAsync(StateHasChanged);
                }
            }, token, TaskContinuationOptions.OnlyOnRanToCompletion, TaskScheduler.Default);
        }
        _prevOp = ActiveOperator;
    }

    private string GetOperatorSymbol() => ActiveOperator.ToSymbol();

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
    }
}
