@using KnockBox.Operator.Models
@using KnockBox.Operator.Services.State

<div class="op-setup">
    @if (IsHost())
    {
        int totalPlayers = GameState.Players.Count;
        int scoresSubmitted = GameState.GamePlayers.Values.Count(state => state.CurrentPoints != 0m);

        <h2 class="op-phase-title">PLAYERS SELECTING STARTING SCORE</h2>

        <div class="op-setup-host-grid">
            @for (int i = 0; i < GameState.Players.Count; i++)
            {
                var player = GameState.Players[i];
                var playerState = GameState.GamePlayers.GetValueOrDefault(player.Id);
                var hasSubmitted = playerState != null && playerState.CurrentPoints != 0m;
                var isPositive = playerState?.CurrentPoints > 0;

                <div class="op-setup-slot @(hasSubmitted ? "ready" : "")" style="--i: @i">
                    <div class="op-setup-slot-avatar @(hasSubmitted ? (isPositive ? "avatar-positive" : "avatar-negative") : "")">
                        @player.Name[0].ToString().ToUpper()
                    </div>
                    <span class="op-setup-slot-name">@player.Name</span>
                    @if (hasSubmitted)
                    {
                        <span class="op-setup-slot-score @(isPositive ? "score-positive" : "score-negative")">
                            @(isPositive ? "+" : "")@playerState!.CurrentPoints.ToString("F1")
                        </span>
                        <span class="op-setup-slot-check">&#10003;</span>
                    }
                    else
                    {
                        <span class="op-setup-slot-score score-pending">---</span>
                        <span class="op-setup-slot-waiting">...</span>
                    }
                </div>
            }
        </div>

        <div class="op-setup-progress">
            <div class="op-setup-progress-dots">
                @for (int i = 0; i < totalPlayers; i++)
                {
                    <span class="op-setup-dot @(i < scoresSubmitted ? "filled" : "")"></span>
                }
            </div>
            <span class="op-setup-progress-text">@scoresSubmitted / @totalPlayers READY</span>
        </div>
    }
    else
    {
        <h2 class="op-phase-title">CHOOSE YOUR STARTING SCORE</h2>
    
        <div class="op-setup-choices">
            <div class="op-choice-btn op-choice-positive" @onclick="() => SubmitChoice(GameState.Config.InitialPointsPositive)">
                <span class="op-choice-value">+@GameState.Config.InitialPointsPositive.ToString("F1")</span>
            </div>

            <div class="op-choice-btn op-choice-negative" @onclick="() => SubmitChoice(GameState.Config.InitialPointsNegative)">
                <span class="op-choice-value">@GameState.Config.InitialPointsNegative.ToString("F1")</span>
            </div>
        </div>
    
        @if (ShouldShowWaiting())
        {
            <div class="op-waiting-section">
                <p class="op-waiting-text">Choice locked! Waiting for others...</p>
            </div>
        }
    }
</div>
