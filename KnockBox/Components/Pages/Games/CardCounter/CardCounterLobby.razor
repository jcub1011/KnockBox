@page "/room/card-counter/{ObfuscatedRoomCode}"

@inherits DisposableComponent
@using KnockBox.Services.State.Games.CardCounter
@using KnockBox.Services.Logic.Games.CardCounter.FSM
@using KnockBox.Core.Services.State.Games.Shared

<PageTitle>Card Counter</PageTitle>

@if (GameState == null)
{
    <div class="cc-loading">
        <span class="cc-loading-icon">🃏</span>
        <span>Loading table...</span>
    </div>
}
else
{
    <div class="cc-page">

        @if (GameState.Config.EnableActionTimer && GameState.Context?.Fsm?.CurrentState is ITimedGameState<CardCounterGameContext, CardCounterCommand> timedState)
        {
            var remaining = timedState.GetRemainingTime(GameState.Context!, DateTimeOffset.UtcNow);
            if (remaining.IsSuccess)
            {
                var seconds = (int)Math.Ceiling(remaining.Value.TotalSeconds);
                if (seconds >= 0)
                {
                    <div class="cc-timer-container">
                        <div class="cc-timer-card @(seconds < 5 ? "cc-timer-urgent" : "")">
                            ⏳ @seconds
                        </div>
                    </div>
                }
            }
        }

        @if (GameState.IsJoinable)
        {
            <LobbyPhase GameState="GameState" />
        }
        else if (GameState.GamePhase == GamePhase.BuyIn)
        {
            <BuyInPhase GameState="GameState" />
        }
        else if (GameState.GamePhase == GamePhase.Playing)
        {
            <PlayingPhase GameState="GameState" IsAnimatingShoe="IsAnimatingShoe" />
        }
        else if (GameState.GamePhase == GamePhase.GameOver)
        {
            <GameOverPhase GameState="GameState" />
        }

    </div>
}
