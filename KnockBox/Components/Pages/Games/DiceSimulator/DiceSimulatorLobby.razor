@page "/room/dice-simulator/{ObfuscatedRoomCode}"

@inherits DisposableComponent
@using KnockBox.Services.State.Games.DiceSimulator.Data

<PageTitle>Dice Simulator</PageTitle>

<div class="content">
@if (GameState == null)
{
    <div>Loading...</div>
}
else
{
    @if (GameState.IsJoinable)
    {
        <div class="card">
            <div class="joinable-state">
                <h4>Players</h4>
                <div class="player-list">
                    @foreach (var player in GameState.Players)
                    {
                        <button class="btn" title="Click to kick player."
                                @onclick="() => GameState.KickPlayer(player)">@player.Name @(player.Id == GameState.Host.Id ? "(Host)" : "")</button>
                    }
                </div>
                @if (UserService.CurrentUser?.Id == GameState.Host.Id)
                {
                    <button class="btn btn-primary start-btn mt-3" @onclick="StartGame">Start Session</button>
                }
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <h3>Roll Controls</h3>
            <div class="labeled-input">
                <label>Dice</label>
                <div class="dice-options">
                    @foreach (var type in Enum.GetValues<DiceType>())
                    {
                        <button class="btn @(RollAction.DiceType == type ? "btn-primary" : "btn-outline-primary")" @onclick="() => RollAction.DiceType = type">d@((int)type)</button>
                    }
                </div>
            </div>
            <div class="input-row">
                <div class="labeled-input">
                    <label>Count: @RollAction.DiceCount</label>
                    <input type="number" class="form-control" min="1" max="99" @bind="RollAction.DiceCount" />
                </div>
                <div class="labeled-input">
                    <label>Modifier: @(RollAction.Modifier >= 0 ? "+" : "")@RollAction.Modifier</label>
                    <input type="number" class="form-control" @bind="RollAction.Modifier" />
                </div>
                <div class="labeled-input">
                    <label>Expression:</label>
                    <div class="expression-preview form-control">
                        @RollAction.DiceCount@("d")@((int)RollAction.DiceType)@(RollAction.Modifier == 0 ? "" : (RollAction.Modifier > 0 ? $"+{RollAction.Modifier}" : RollAction.Modifier.ToString()))
                    </div>
                </div>
            </div>
            <div class="labeled-input">
                <label>Mode</label>
                <select class="form-control" @bind="RollAction.Mode">
                    @foreach (var mode in Enum.GetValues<RollMode>())
                    {
                        <option value="@mode">@mode</option>
                    }
                </select>
            </div>
            <div class="input-row">
                <button class="btn btn-success flex-1" @onclick="RollDice">ROLL!</button>
                @if (UserService.CurrentUser?.Id == GameState.Host.Id)
                {
                    <button class="btn btn-danger flex-1" @onclick="ClearHistory">Clear History</button>
                }
            </div>
            <div class="">
                @if (GameState.RollHistory.Where(r => r.PlayerId == UserService.CurrentUser?.Id).LastOrDefault() is { } lastRoll)
                {
                    <div class="alert alert-info">
                        <strong>Last Roll:</strong> @lastRoll.Expression = @lastRoll.Result <br/>
                        <small>Mode: @lastRoll.Mode | Rolled: @string.Join(", ", lastRoll.RawRolls)</small>
                    </div>
                }
            </div>
        </div>
        <div class="leaderboard-panel card">
            <h4>Leaderboard</h4>
            <div class="table-responsive">
                <table class="table table-sm table-striped jackbox-table">
                    <thead>
                        <tr>
                            <th>Player</th>
                            <th>Rolls</th>
                            <th>Dice Rolled</th>
                            <th>Nat 20s</th>
                            <th>Nat 1s</th>
                            <th>Highest</th>
                            <th>Cumulative</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var stats in GameState.PlayerStats.Values.OrderByDescending(s => s.TotalRolls))
                        {
                            <tr>
                                <td>@stats.PlayerName</td>
                                <td>@stats.TotalRolls</td>
                                <td>@stats.TotalDiceRolled</td>
                                <td>@stats.NatTwentyCount</td>
                                <td>@stats.NatOneCount</td>
                                <td>@stats.HighestResult (@stats.HighestResultExpression)</td>
                                <td>@stats.CumulativeTotal</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card">
            <div class="d-flex justify-content-between align-items-center">
                <h4>Player Rolls</h4>
                <button class="btn btn-sm btn-outline-secondary export-btn" @onclick="ExportCsv">Export CSV ▼</button>
            </div>
            <div class="player-rolls-list">
                @foreach (var player in Enumerable.Repeat(GameState.Host, 1).Concat(GameState.Players))
                {
                    var playerLastRoll = GameState.RollHistory.LastOrDefault(r => r.PlayerId == player.Id);
                    var isExpanded = IsPlayerExpanded(player.Id);
                    <div class="player-roll-row" @onclick="() => TogglePlayerHistory(player.Id)">
                        <div class="player-roll-summary">
                            <span class="player-roll-name">@player.Name</span>
                            @if (playerLastRoll is not null)
                            {
                                <span class="player-roll-result">@playerLastRoll.Expression = <strong>@playerLastRoll.Result</strong></span>
                                <span class="player-roll-time">
                                    @((DateTimeOffset.UtcNow - playerLastRoll.Timestamp).TotalSeconds < 60
                                        ? "Just now"
                                        : $"{(int)(DateTimeOffset.UtcNow - playerLastRoll.Timestamp).TotalMinutes}m ago")
                                </span>
                            }
                            else
                            {
                                <span class="player-roll-empty">No rolls yet</span>
                            }
                            <span class="player-roll-toggle">@(isExpanded ? "▲" : "▼")</span>
                        </div>
                    </div>
                    @if (isExpanded)
                    {
                        <div class="player-roll-history jackbox-list">
                            @foreach (var roll in GameState.RollHistory.Where(r => r.PlayerId == player.Id).Reverse().Take(200))
                            {
                                <div class="list-group-item flex-column align-items-start">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6>@roll.Expression = @roll.Result</h6>
                                        <small>@((DateTimeOffset.UtcNow - roll.Timestamp).TotalSeconds < 60 ? "Just now" : $"{(int)(DateTimeOffset.UtcNow - roll.Timestamp).TotalMinutes}m ago")</small>
                                    </div>
                                    <p>
                                        @if (roll.Mode != RollMode.Normal && roll.AltRolls != null)
                                        {
                                            <span>(@roll.Mode &mdash; kept: @(roll.RawRolls.Sum()) [@string.Join(",", roll.RawRolls)] | alt: @roll.AltTotal [@string.Join(",", roll.AltRolls)])</span>
                                        }
                                        else
                                        {
                                            <span>(rolls: @string.Join(",", roll.RawRolls) @(roll.Modifier != 0 ? (roll.Modifier > 0 ? $"+ {roll.Modifier}" : $"- {Math.Abs(roll.Modifier)}") : ""))</span>
                                        }
                                    </p>
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    }
}
</div>