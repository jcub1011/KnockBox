@page "/"

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

@if (isLoaded)
{
    <p>Welcome to your new app.</p>
}
else
{
    <p>Loading...</p>
}

@code {
    private bool isLoaded = false;

    protected override async Task OnInitializedAsync()
    {
        StateHasChanged();
        await Task.Delay(5000);
        isLoaded = true;
        StateHasChanged();
    }
}