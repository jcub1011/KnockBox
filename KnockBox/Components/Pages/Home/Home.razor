@page "/"
@page "/home"

@inherits DisposableComponent

<PageTitle>Knockbox Games</PageTitle>

<div class="home-container @(_isTransitioning ? "transitioning" : "")">
    <div class="hero">
        <h1 class="title">
            <span class="title-letter" aria-hidden="true">K</span>
            <span class="title-letter" aria-hidden="true">n</span>
            <span class="title-letter" aria-hidden="true">o</span>
            <span class="title-letter" aria-hidden="true">c</span>
            <span class="title-letter" aria-hidden="true">k</span>
            <span class="title-letter" aria-hidden="true">b</span>
            <span class="title-letter" aria-hidden="true">o</span>
            <span class="title-letter" aria-hidden="true">x</span>
            <span class="sr-only">Knockbox</span>
        </h1>
    </div>

    <form @onsubmit="() => JoinLobby(LobbyCode ?? string.Empty)" @onsubmit:preventDefault="true">
        <div class="join-section">
            <div class="join-card join-card-name">
                <label class="join-label" for="player-name-input">Player Name</label>
                <input id="player-name-input"
                       placeholder="Enter name"
                       type="text" maxlength="12" name="player-name"
                       @bind="PlayerName" @bind:event="oninput" style="text-transform: none;"/>
            </div>

            <div class="join-card join-card-code">
                <label class="join-label" for="room-code-input">Room Code</label>
                <div class="join-code-row">
                    <input id="room-code-input"
                           placeholder="KN0CK3OX"
                           type="text" maxlength="@LobbyCodeService.LobbyCodeLength" name="room-code"
                           @bind="LobbyCode"/>
                    <button type="submit" class="join-btn" disabled="@(!CanJoinOrCreate)">Join</button>
                </div>
            </div>
        </div>
    </form>

    <div class="games-section">
        <h2 class="games-heading">
            <span class="games-heading-icon" aria-hidden="true">&#127922;</span>
            Pick a Game
        </h2>
        <div class="game-grid">
            @foreach (var module in GameModules.OrderBy(m => m.Name))
            {
                <button class="game-tile" aria-label="@module.Name" disabled="@(!CanJoinOrCreate)" @onclick="() => CreateLobby(module.RouteIdentifier)">
                    @module.GetButtonContent()
                </button>
            }
        </div>
    </div>
</div>
