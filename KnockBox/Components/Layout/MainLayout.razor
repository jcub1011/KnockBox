@using KnockBox.Core.Services.Navigation
@using KnockBox.Core.Services.State.Games.Shared
@using KnockBox.Core.Services.State.Users
@using Microsoft.AspNetCore.Components.Routing

@inherits LayoutComponentBase
@implements IDisposable

<div class="main">
    <header class="@(_isOnHomePage ? "home-header" : "") @(_isEnteringGame ? "entering-from-home" : "") @(_isExitingGame ? "exiting-to-home" : "")">
        @if (!_isOnHomePage && GameSessionService.TryGetCurrentSession(out var currentSession))
        {
            <a href="@NavigationService.GetHomeUri()" title="Click to return home">
                @currentSession.LobbyRegistration.GameName</a>
            <div class="header-actions">
                <button class="room-code-btn @(_isRoomCodeRevealed ? "revealed" : "")"
                        @onclick="ToggleRoomCode"
                        @onmouseup="OnMouseUp"
                        @oncontextmenu="@(() => CopyRoomCodeAsync(currentSession.LobbyRegistration.Code))"
                        @oncontextmenu:preventDefault="true"
                        title="Click to reveal. Right-click/Long-press to copy. Middle-click to join in a new tab.">
                    <span class="room-code-cover">Join Code</span>
                    <span class="room-code-value">@currentSession.LobbyRegistration.Code</span>
                </button>
                <button class="leave-session-btn" @onclick="LeaveSession" title="Leave Session">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
                </button>
            </div>
        }
        else
        {
            <span>Knockbox</span>
        }
    </header>
    <article class="@(_isEnteringGame ? "entering-from-home" : "") @(_isExitingGame ? "exiting-to-home" : "")">
        @Body
        <div id="blazor-error-ui" data-nosnippet>
            An unhandled error has occurred.
            <a href="." class="reload">Reload</a>
            <span class="dismiss">🗙</span>
        </div>
    </article>
</div>

@code {
    [Inject] INavigationService NavigationService { get; set; } = default!;
    [Inject] IGameSessionService GameSessionService { get; set; } = default!;
    [Inject] IUserService UserService { get; set; } = default!;
    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] IJSRuntime JSRuntime { get; set; } = default!;
    [Inject] ILogger<MainLayout> Logger { get; set; } = default!;

    private bool _isRoomCodeRevealed;
    private bool _isOnHomePage;
    private bool _isEnteringGame;
    private bool _isExitingGame;
    private IDisposable? _locationChangingRegistration;
    private CancellationTokenSource _cts = new();

    protected override void OnInitialized()
    {
        _isOnHomePage = IsHomePage();
        NavigationManager.LocationChanged += OnLocationChanged;
        UserService.UserInitialized += OnUserInitialized;
        _locationChangingRegistration = NavigationManager.RegisterLocationChangingHandler(OnLocationChanging);
    }

    private async ValueTask OnLocationChanging(LocationChangingContext context)
    {
        if (_isOnHomePage || _isExitingGame) return;

        var targetRelPath = NavigationManager.ToBaseRelativePath(context.TargetLocation).TrimEnd('/');
        if (targetRelPath is not ("" or "home")) return;

        _isExitingGame = true;
        await InvokeAsync(StateHasChanged);
        await Task.Delay(400);
        _isExitingGame = false;
        
        // Ensure the session is cleaned up when navigating to the home page (via link or back button).
        GameSessionService.LeaveCurrentSession(navigateHome: false);
    }

    private bool IsHomePage()
    {
        var relPath = NavigationManager.ToBaseRelativePath(NavigationManager.Uri).TrimEnd('/');
        return relPath is "" or "home";
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var wasHome = _isOnHomePage;
        _isOnHomePage = IsHomePage();
        // Reset the room-code reveal state when the user navigates away from/to a room.
        _isRoomCodeRevealed = false;
        _isExitingGame = false;

        if (wasHome && !_isOnHomePage)
        {
            _isEnteringGame = true;
            var token = _cts.Token;
            _ = Task.Delay(600, token).ContinueWith(_ => InvokeAsync(() =>
            {
                _isEnteringGame = false;
                StateHasChanged();
            }), token, TaskContinuationOptions.OnlyOnRanToCompletion, TaskScheduler.Current);
        }

        _ = InvokeAsync(StateHasChanged).ContinueWith(
            t => Logger.LogError(t.Exception, "Error refreshing layout after navigation."),
            TaskContinuationOptions.OnlyOnFaulted);
    }

    private void OnUserInitialized()
    {
        _ = InvokeAsync(StateHasChanged).ContinueWith(
            t => Logger.LogError(t.Exception, "Error refreshing layout after user initialization."),
            TaskContinuationOptions.OnlyOnFaulted);
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        NavigationManager.LocationChanged -= OnLocationChanged;
        UserService.UserInitialized -= OnUserInitialized;
        _locationChangingRegistration?.Dispose();
    }

    private void ToggleRoomCode() => _isRoomCodeRevealed = !_isRoomCodeRevealed;

    private void LeaveSession() => GameSessionService.LeaveCurrentSession(navigateHome: true);

    private async Task OnMouseUp(MouseEventArgs e)
    {
        // Button 1 is the middle mouse button.
        if (e.Button == 1 && GameSessionService.TryGetCurrentSession(out var session))
        {
            var url = NavigationService.GetJoinUri(session.LobbyRegistration.Code, fresh: true);
            await JSRuntime.InvokeVoidAsync("window.open", url, "_blank");
        }
    }

    private async Task CopyRoomCodeAsync(string code)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", code);
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error copying lobby code.");
        }
    }
}
