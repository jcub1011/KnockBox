@namespace KnockBox.Components.Shared
@using System.Globalization
@using KnockBox.Services.Drawing
@implements IAsyncDisposable

<div class="svg-drawing-canvas">
    @if (ShowToolbar)
    {
        <div class="svg-drawing-canvas__toolbar">
            <label class="svg-drawing-canvas__control">
                <span>Brush color</span>
                <input type="color"
                       value="@_brushColor"
                       @oninput="HandleBrushColorInputAsync"
                       aria-label="Brush color" />
            </label>

            <label class="svg-drawing-canvas__control svg-drawing-canvas__control--size">
                <span>Brush size</span>
                <input type="range"
                       min="@SvgDrawingDocument.MinimumBrushSize.ToString(CultureInfo.InvariantCulture)"
                       max="@SvgDrawingDocument.MaximumBrushSize.ToString(CultureInfo.InvariantCulture)"
                       step="1"
                       value="@_brushSize.ToString(CultureInfo.InvariantCulture)"
                       @oninput="HandleBrushSizeInputAsync"
                       aria-label="Brush size" />
                <output>@_brushSize.ToString("0", CultureInfo.InvariantCulture)px</output>
            </label>

            <label class="svg-drawing-canvas__control">
                <span>Background</span>
                <input type="color"
                       value="@_backgroundColor"
                       @oninput="HandleBackgroundColorInputAsync"
                       aria-label="Canvas background color" />
            </label>

            <button type="button" @onclick="UndoAsync" disabled="@(!_document.CanUndo)">Undo</button>
            <button type="button" @onclick="DownloadSvgAsync">Export SVG</button>
        </div>
    }

    <div class="svg-drawing-canvas__surface"
         style="@BuildSurfaceStyle()"
         @ref="_surfaceReference">
        <svg class="svg-drawing-canvas__svg"
             viewBox="0 0 @_canvasWidth @_canvasHeight"
             preserveAspectRatio="none"
             @onpointerdown="HandlePointerDownAsync"
             @onpointermove="HandlePointerMove"
             @onpointerup="HandlePointerUpAsync"
             @onpointercancel="HandlePointerCancelAsync"
             @onpointerleave="HandlePointerLeaveAsync"
             @onpointerdown:preventDefault="true"
             @onpointermove:preventDefault="true">
            <rect width="100%" height="100%" fill="@_backgroundColor" />

            @foreach (var stroke in _document.Strokes)
            {
                @if (stroke.Points.Count == 1)
                {
                    var point = stroke.Points[0];
                    <circle cx="@point.X.ToString("0.###", CultureInfo.InvariantCulture)"
                            cy="@point.Y.ToString("0.###", CultureInfo.InvariantCulture)"
                            r="@(stroke.StrokeSize / 2d).ToString("0.###", CultureInfo.InvariantCulture)"
                            fill="@stroke.Color" />
                }
                else if (stroke.Points.Count > 1)
                {
                    <polyline points="@GetPointList(stroke)"
                              fill="none"
                              stroke="@stroke.Color"
                              stroke-width="@stroke.StrokeSize.ToString("0.###", CultureInfo.InvariantCulture)"
                              stroke-linecap="round"
                              stroke-linejoin="round" />
                }
            }
        </svg>
    </div>
</div>
