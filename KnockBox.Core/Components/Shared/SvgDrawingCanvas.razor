@namespace KnockBox.Core.Components.Shared
@using Microsoft.JSInterop

<div class="svg-drawing-canvas" style="width: @Width; height: @Height;">
    <div class="svg-canvas-toolbar">
        <div class="toolbar-group">
            <label class="toolbar-label">Colors</label>
            <div class="toolbar-swatches">
                @foreach (var swatch in _colorSwatches)
                {
                    var isActive = string.Equals(swatch, _currentColor, StringComparison.OrdinalIgnoreCase);
                    <button class="toolbar-swatch @(isActive ? "toolbar-swatch-active" : "")"
                            style="background-color: @swatch;"
                            title="@swatch"
                            @onclick="() => OnSwatchClickedAsync(swatch)"></button>
                }
            </div>
            <input id="@_colorInputId" type="color" class="toolbar-color"
                   value="@_currentColor"
                   title="Custom color" />
        </div>
        <div class="toolbar-group">
            <label class="toolbar-label" for="@_sizeInputId">Size: @_currentStrokeWidth</label>
            <input id="@_sizeInputId" type="range" class="toolbar-size"
                   min="1" max="30" step="1"
                   value="@_currentStrokeWidth" />
        </div>
        <button class="toolbar-btn" @onclick="UndoAsync" disabled="@(_strokeCount == 0)">↩ Undo</button>
        <button class="toolbar-btn toolbar-btn-export" @onclick="ExportSvgAsync">⬇ Export SVG</button>
    </div>
    <svg id="@_svgId" class="svg-canvas-surface" style="background-color: @BackgroundColor;"></svg>
</div>
