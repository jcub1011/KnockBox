@using KnockBox.HiddenAgenda.Services.State.Games
@using KnockBox.HiddenAgenda.Services.Logic.Games.Data

<div class="ha-card-picker">
    <h4 class="ha-heading">Select a Curation Card</h4>
    <div class="ha-card-picker-cards">
        @for (int i = 0; i < Cards.Count; i++)
        {
            var index = i;
            var card = Cards[i];
            <div class="ha-curation-card ha-curation-card-@card.Type.ToString().ToLower()" @onclick="() => OnCardSelected?.Invoke(index)">
                <div class="ha-curation-card-header">@card.Type</div>
                <div class="ha-curation-card-body">
                    <p class="ha-curation-card-desc">@card.Description</p>
                    <ul class="ha-curation-card-effects">
                        @foreach (var effect in card.Effects)
                        {
                            <li class="@(effect.Delta > 0 ? "ha-positive" : "ha-negative")">@effect.Collection @(effect.Delta > 0 ? "+" : "")@effect.Delta</li>
                        }
                    </ul>
                </div>
                @if (card.Type == CurationCardType.Trade)
                {
                    <div class="ha-curation-card-trade-badge">Trade Card</div>
                }
            </div>
        }
    </div>
</div>
