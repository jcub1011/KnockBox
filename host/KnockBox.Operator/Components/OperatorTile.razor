<div class="game-tile-surface op-tile">
    <div class="op-bloom" aria-hidden="true"></div>

    <div class="op-stage" aria-hidden="true">
        <div class="op-deck-card op-deck-card-back-2"></div>
        <div class="op-deck-card op-deck-card-back-1"></div>
        <div class="op-operator-card">
            <span class="op-symbol op-symbol-plus">+</span>
            <span class="op-symbol op-symbol-minus">&#8722;</span>
            <span class="op-symbol op-symbol-times">&#215;</span>
            <span class="op-symbol op-symbol-div">&#247;</span>
        </div>
    </div>

    <div class="op-score" aria-hidden="true">
        <span class="op-score-delta">+1</span>
        <span class="op-score-value">7</span>
    </div>

    <div class="op-tile-name">Operator</div>
    <div class="op-tile-tag">Stack operators. Strike opponents.</div>
</div>
