@page "/admin/changepassword"
@layout AdminLayout
@using KnockBox.Services.Logic.Admin
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Admin")]
@inject IAdminSettingsService Settings
@inject NavigationManager Nav
@inject ILogger<ChangePassword> Logger

<PageTitle>KnockBox Admin - Change Password</PageTitle>

<div class="admin-change-password-container">
    <div class="admin-login-card">
        <h1 class="admin-login-title">Change Admin Password</h1>
        <p class="admin-login-subtitle">
            You are currently using the default password. You must change it before accessing the dashboard.
        </p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="admin-login-error">@_error</div>
        }

        @if (_success)
        {
            <div class="admin-status-enabled" style="margin-bottom: 1rem; font-size: 0.9rem;">
                Password updated successfully! Redirecting...
            </div>
        }
        else
        {
            <form @onsubmit="HandleSubmit">
                <label class="admin-login-label" for="new-password">New Password</label>
                <input id="new-password" type="password" @bind="_newPassword" required autofocus />

                <label class="admin-login-label" for="confirm-password">Confirm Password</label>
                <input id="confirm-password" type="password" @bind="_confirmPassword" required />

                <button class="admin-login-submit" type="submit" disabled="@(_isSubmitting)">
                    @(_isSubmitting ? "Updating..." : "Update Password")
                </button>
            </form>
        }
    </div>
</div>

<style>
    .admin-change-password-container {
        display: grid;
        place-items: center;
        height: 60vh;
    }
</style>

@code {
    private string _newPassword = string.Empty;
    private string _confirmPassword = string.Empty;
    private string? _error;
    private bool _isSubmitting;
    private bool _success;

    private async Task HandleSubmit()
    {
        _error = null;

        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            _error = "Password cannot be empty.";
            return;
        }

        if (_newPassword == "changeme")
        {
            _error = "You cannot use 'changeme' as your new password.";
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            _error = "Passwords do not match.";
            return;
        }

        if (_newPassword.Length < 8)
        {
            _error = "Password must be at least 8 characters long.";
            return;
        }

        _isSubmitting = true;
        try
        {
            await Settings.UpdatePasswordAsync(_newPassword);
            _success = true;
            StateHasChanged();

            Logger.LogInformation("Admin password changed successfully.");

            // Short delay to show success message
            await Task.Delay(1500);
            Nav.NavigateTo("/admin");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to update admin password.");
            _error = "An unexpected error occurred. Please check the logs.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
