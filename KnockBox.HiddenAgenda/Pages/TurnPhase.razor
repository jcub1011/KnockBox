@using KnockBox.HiddenAgenda.Services.State.Games
@using KnockBox.HiddenAgenda.Services.State.Games.Data
@using KnockBox.HiddenAgenda.Services.Logic.Games
@using KnockBox.HiddenAgenda.Services.Logic.Games.Data
@using KnockBox.Core.Services.State.Users
@using KnockBox.HiddenAgenda.Components

<div class="turn-phase-layout">
    <!-- Sidebar: Game Status & Collections -->
    <div class="turn-sidebar">
        <div class="card status-card">
            <h4>@CurrentPlayerName's Turn</h4>
            <div class="turn-counter">Turns Taken: @GameState.TotalTurnsTaken</div>
            @if (GameState.GuessCountdownActive)
            {
                <div class="guess-countdown text-danger">Guess window active!</div>
            }
        </div>

        <div class="card players-card mt-3">
            <h4>Players</h4>
            <div class="player-statuses">
                @foreach (var player in GameState.GamePlayers.Values)
                {
                    <div class="player-status d-flex justify-content-between align-items-center mb-1">
                        <span>@player.DisplayName</span>
                        @if (player.HeldEventCard is not null)
                        {
                            <span class="badge badge-info" title="Holding Event Card">🎴</span>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card collections-card mt-3">
            <h4>Collections</h4>
            <CollectionTracks Progress="GameState.CollectionProgress" />
        </div>

        <div class="card history-card mt-3">
            <h4>History</h4>
            <div class="history-log">
                @foreach (var entry in GameState.RoundPlayHistory.AsEnumerable().Reverse())
                {
                    <div class="history-entry">Turn @entry.TurnNumber: @(GameState.Players.FirstOrDefault(p => p.Id == entry.PlayerId)?.Name) moved to @entry.SpaceId</div>
                }
            </div>
        </div>
    </div>

    <!-- Main Area: Board and Current Phase Controls -->
    <div class="turn-main">
        <div class="board-container card">
            <BoardView GameState="GameState" OnSpaceClicked="HandleSpaceClicked" />
        </div>

        <div class="phase-controls card mt-3">
            @if (IsCurrentPlayer)
            {
                @switch (GameState.Phase)
                {
                    case GamePhase.EventCardPhase:
                        <div class="event-card-controls text-center">
                            @if (CurrentPlayerState?.HeldEventCard is not null)
                            {
                                <h4>Held Event Card: @CurrentPlayerState.HeldEventCard.Type</h4>
                                <p>@CurrentPlayerState.HeldEventCard.Description</p>
                                
                                @if (CurrentPlayerState.HeldEventCard.Type == EventCardType.Catalog || 
                                     CurrentPlayerState.HeldEventCard.Type == EventCardType.Detour)
                                {
                                    <div class="target-selection mt-2">
                                        <label>Select Target Player:</label>
                                        <select class="form-control" @bind="_selectedTargetPlayerId">
                                            <option value="">-- Select --</option>
                                            @foreach (var player in GameState.Players.Where(p => p.Id != UserService.CurrentUser?.Id))
                                            {
                                                <option value="@player.Id">@player.Name</option>
                                            }
                                        </select>
                                    </div>
                                }

                                <div class="mt-3">
                                    <button class="btn btn-primary" @onclick="PlayEventCard">Play Card</button>
                                    <button class="btn btn-secondary" @onclick="SkipEventCard">Skip</button>
                                </div>
                            }
                            else
                            {
                                <p>No event card to play.</p>
                                <button class="btn btn-secondary" @onclick="SkipEventCard">Continue</button>
                            }
                        </div>
                        break;

                    case GamePhase.SpinPhase:
                        <div class="spin-controls text-center">
                            <SpinnerWheel Result="GameState.CurrentSpinResult" 
                                          OnSpin="HandleSpin" 
                                          IsCurrentPlayer="true" />
                        </div>
                        break;

                    case GamePhase.MovePhase:
                        <div class="move-controls text-center">
                            <h4>Move Phase</h4>
                            <p>Move up to @GameState.CurrentSpinResult spaces. Click a space on the board or select below.</p>
                            <div class="move-options mt-2">
                                @if (GameState.ReachableSpaces is not null)
                                {
                                    @foreach (var space in GameState.ReachableSpaces)
                                    {
                                        <button class="btn btn-outline-info m-1" @onclick="() => HandleSpaceClicked(space.Id)">Space @space.Id (@space.Wing)</button>
                                    }
                                }
                            </div>
                        </div>
                        break;

                    case GamePhase.DrawPhase:
                        <div class="draw-controls">
                            @if (GameState.DrawnCards is not null && GameState.DrawnCards.Any())
                            {
                                <CurationCardPicker Cards="GameState.DrawnCards" OnCardSelected="HandleCardSelected" />
                            }
                            else if (GameState.PendingDrawnEventCard is not null)
                            {
                                <div class="event-choice text-center">
                                    <h4>Event Spot Choice</h4>
                                    <div class="row">
                                        <div class="col card p-3 m-2">
                                            <h5>Keep Current Card</h5>
                                            <p><strong>@CurrentPlayerState?.HeldEventCard?.Type</strong></p>
                                            <p class="small text-muted">@CurrentPlayerState?.HeldEventCard?.Description</p>
                                            <button class="btn btn-secondary" @onclick="() => HandleEventChoice(false)">Keep</button>
                                        </div>
                                        <div class="col card p-3 m-2">
                                            <h5>Swap for New Card</h5>
                                            <p><strong>@GameState.PendingDrawnEventCard?.Type</strong></p>
                                            <p class="small text-muted">@GameState.PendingDrawnEventCard?.Description</p>
                                            <button class="btn btn-primary" @onclick="() => HandleEventChoice(true)">Swap</button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        break;
                }
            }
            else
            {
                <div class="waiting-message text-center">
                    <p>Waiting for @CurrentPlayerName to complete their @GameState.Phase...</p>
                </div>
            }

            <div class="dossier-reference mt-4 p-3">
                <h5>Your Dossier</h5>
                <DossierPanel TaskPool="GameState.CurrentTaskPool" PlayerTasks="PlayerTasks" />
            </div>
        </div>
    </div>
</div>

@if (_errorMessage != null)
{
    <div class="error-toast" @key="_errorKey">@_errorMessage</div>
}
