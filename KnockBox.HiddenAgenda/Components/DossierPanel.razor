@using KnockBox.HiddenAgenda.Services.State.Games

<div class="ha-dossier">
    <div class="ha-dossier-header" @onclick="Toggle">
        <h5 class="ha-dossier-title">Dossier</h5>
        <button class="ha-btn ha-btn-ghost ha-btn-sm">@(_isCollapsed ? "Expand" : "Collapse")</button>
    </div>

    @if (!_isCollapsed)
    {
        <div class="ha-dossier-body">
            @foreach (var category in Categories)
            {
                <div class="ha-dossier-category">
                    <h6 class="ha-dossier-category-title">@category</h6>
                    <ul class="ha-task-list">
                        @foreach (var task in GetTasksByCategory(category))
                        {
                            <li class="ha-task-row @(IsPlayerTask(task.Id) ? "ha-task-mine" : "")">
                                <span class="ha-task-id">@task.Id</span>
                                <span class="ha-task-desc">@task.Description</span>
                                <span class="ha-task-points">@task.PointValue pts</span>
                            </li>
                        }
                    </ul>
                </div>
            }
        </div>
    }
</div>
