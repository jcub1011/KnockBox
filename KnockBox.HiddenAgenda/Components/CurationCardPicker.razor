@using KnockBox.HiddenAgenda.Services.State.Games
@using KnockBox.HiddenAgenda.Services.Logic.Games.Data

<div class="curation-card-picker">
    <h4>Select a Curation Card</h4>
    <div class="cards-container">
        @for (int i = 0; i < Cards.Count; i++)
        {
            var index = i;
            var card = Cards[i];
            <div class="card curation-card @(card.Type.ToString().ToLower())" @onclick="() => OnCardSelected?.Invoke(index)">
                <div class="card-header">@card.Type</div>
                <div class="card-body">
                    <p class="description">@card.Description</p>
                    <ul class="effects-list">
                        @foreach (var effect in card.Effects)
                        {
                            <li>@effect.Collection @(effect.Delta > 0 ? "+" : "")@effect.Delta</li>
                        }
                    </ul>
                </div>
                @if (card.Type == CurationCardType.Trade)
                {
                    <div class="trade-info badge badge-info">Trade Card</div>
                }
            </div>
        }
    </div>
</div>
