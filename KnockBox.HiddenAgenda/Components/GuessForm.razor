@using KnockBox.HiddenAgenda.Services.State.Games

<div class="guess-form card p-3">
    @foreach (var opponent in Opponents)
    {
        <div class="opponent-guess mb-4 border-bottom pb-3">
            <h5 class="opponent-name">Guess tasks for <strong>@opponent.DisplayName</strong>:</h5>
            <div class="task-selections d-flex flex-wrap gap-2">
                @for (int i = 0; i < 3; i++)
                {
                    var index = i;
                    <div class="task-select-container flex-grow-1" style="min-width: 250px;">
                        <select class="form-control" @bind="Guesses[opponent.PlayerId][index]">
                            <option value="">-- Select Task --</option>
                            @foreach (var task in TaskPool)
                            {
                                <option value="@task.Id">[@task.Category] @task.Id: @task.Description</option>
                            }
                        </select>
                    </div>
                }
            </div>
        </div>
    }

    <div class="submit-section text-center mt-3">
        @if (!Validate())
        {
            <p class="text-danger">Each opponent must have 3 unique tasks assigned.</p>
        }
        <button class="btn btn-primary btn-lg" disabled="@(!Validate())" @onclick="Submit">Submit All Guesses</button>
    </div>
</div>
