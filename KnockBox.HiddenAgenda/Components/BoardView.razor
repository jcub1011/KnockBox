@using KnockBox.HiddenAgenda.Services.State.Games
@using KnockBox.HiddenAgenda.Services.Logic.Games.Data

<div class="board-grid">
    @foreach (var wing in Wings)
    {
        <div class="wing wing-@wing.ToLower()">
            <h5>@wing Wing</h5>
            <div class="spaces">
                @foreach (var space in GetSpacesForWing(wing))
                {
                    <div class="space-node @(space.SpotType == SpotType.Curation ? "curation" : "event") @(IsHighlighted(space.Id) ? "highlighted" : "")"
                         @onclick="() => OnSpaceClicked?.Invoke(space.Id)">
                        <span class="space-id">@space.Id</span>
                        <div class="player-tokens">
                            @foreach (var player in GetPlayersAtSpace(space.Id))
                            {
                                <div class="player-token" style="background-color: @GetPlayerColor(player.PlayerId)" title="@player.DisplayName"></div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
