@using KnockBox.HiddenAgenda.Services.State.Games
@using KnockBox.HiddenAgenda.Services.Logic.Games.Data

<div class="ha-board-grid">
    @foreach (var wing in Wings)
    {
        <div class="ha-board-wing ha-board-wing-@wing.ToLower()">
            <h5 class="ha-board-wing-title">@wing</h5>
            <div class="ha-board-spaces">
                @foreach (var space in GetSpacesForWing(wing))
                {
                    <div class="ha-board-space @(space.SpotType == SpotType.Curation ? "ha-board-space-curation" : "ha-board-space-event") @(IsHighlighted(space.Id) ? "ha-board-space-highlighted" : "")"
                         @onclick="() => OnSpaceClicked?.Invoke(space.Id)">
                        <span class="ha-board-space-id">@space.Id</span>
                        <div class="ha-board-tokens">
                            @foreach (var player in GetPlayersAtSpace(space.Id))
                            {
                                <div class="ha-board-token" style="background-color: @GetPlayerColor(player.PlayerId)" title="@player.DisplayName"></div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
